<!DOCTYPE html>
<html lang="en" id="html-root" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dashboard Teknik P1</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        /* --- Kustomisasi Layout Sidebar & Wrapper --- */
        body { 
            overflow-x: hidden; 
            transition: background-color 0.2s ease, color 0.2s ease;
        }
        
        #wrapper {
            display: flex;
            width: 100vw;
            height: 100vh;
            overflow: hidden;
        }

        /* Sidebar Styling - OPTIMASI GPU */
        #sidebar-wrapper {
            min-height: 100vh;
            width: 250px;
            /* Gunakan transisi yang lebih cepat (0.2s) dengan bezier curve agar snappy */
            transition: width 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            /* PERINTAH SAKTI: Beritahu GPU untuk bersiap mengubah width */
            will-change: width; 
            display: flex;
            flex-direction: column;
            z-index: 1000;
            overflow: hidden; /* Cegah teks tumpah saat menyusut */
        }

        #sidebar-wrapper.collapsed {
            width: 75px;
        }

        /* --- HEADER SIDEBAR (AREA LOGO) --- */
        .sidebar-heading {
            min-height: 65px;
            overflow: hidden;
            cursor: pointer;
            transition: background-color 0.2s ease;
            white-space: nowrap; /* Cegah teks turun ke bawah saat animasi */
        }
        .sidebar-heading:hover {
            background-color: rgba(255,255,255,0.05);
        }

        .collapsed-view { display: none; }
        .expanded-view { display: flex; }

        #sidebar-wrapper.collapsed .expanded-view { display: none !important; }
        #sidebar-wrapper.collapsed .collapsed-view { display: flex; }

        /* Item Menu Navigasi */
        .sidebar-menu .list-group-item {
            border: none;
            padding: 1rem 1.5rem;
            white-space: nowrap; /* Wajib agar teks tidak patah-patah */
            overflow: hidden;
            display: flex;
            align-items: center;
            background: transparent;
            color: #d1d5db; 
            transition: background 0.2s, color 0.2s;
        }

        .sidebar-menu .list-group-item:hover, .sidebar-menu .list-group-item.active {
            background-color: rgba(255, 255, 255, 0.1);
            color: #ffffff;
            border-left: 4px solid #ffc107;
        }

        .sidebar-menu .list-group-item i {
            font-size: 1.3rem;
            margin-right: 15px;
            min-width: 25px;
            text-align: center;
        }

        /* Menu Navigasi Mode Sembunyi */
        #sidebar-wrapper.collapsed .list-group-item {
            padding: 1rem;
            justify-content: center;
            border-left: none; 
        }
        #sidebar-wrapper.collapsed .list-group-item.active {
            background-color: rgba(255, 255, 255, 0.1);
        }
        #sidebar-wrapper.collapsed .list-group-item i {
            margin-right: 0;
        }
        #sidebar-wrapper.collapsed .nav-text {
            display: none;
        }

        /* Area Konten Utama - OPTIMASI ANTI LAG */
        #page-content-wrapper {
            flex-grow: 1;
            overflow-y: auto;
            overflow-x: hidden; /* PERINTAH SAKTI 2: Cegah scrollbar horizontal berkedip saat animasi */
            display: flex;
            flex-direction: column;
            /* Tambahkan will-change agar konten web tidak kaget saat didorong sidebar */
            will-change: width, flex-grow; 
        }

        #top-navbar {
            transition: background-color 0.2s ease;
        }
    </style>
</head>
<body class="bg-body-tertiary">

    <div id="wrapper">
        <div class="bg-dark" id="sidebar-wrapper">
            
            <div class="sidebar-heading border-bottom border-secondary d-flex align-items-center justify-content-center w-100" id="sidebarToggleArea" title="Klik untuk sembunyikan/buka menu">
                
                <div class="expanded-view flex-column align-items-center justify-content-center py-3 w-100">
                    <img src="~/images/logo_indofood.svg" alt="Logo" height="38" class="mb-2" style="object-fit: contain;">
                    <span class="fw-bold text-warning text-center" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                        Teknik P1 Super App
                    </span>
                </div>

                <div class="collapsed-view align-items-center justify-content-center w-100 py-3 text-white">
                    <i class="bi bi-list fs-2"></i>
                </div>

            </div>
            
            <div class="list-group list-group-flush sidebar-menu mt-3 flex-grow-1">
                <a href="/" class="list-group-item list-group-item-action text-decoration-none">
                    <i class="bi bi-bar-chart-fill"></i> <span class="nav-text">Analitik Performa</span>
                </a>
                <a href="/Temuan" class="list-group-item list-group-item-action text-decoration-none">
                    <i class="bi bi-tools"></i> <span class="nav-text">Log Kerusakan</span>
                </a>
                <a href="/Upload" class="list-group-item list-group-item-action text-decoration-none">
                    <i class="bi bi-cloud-arrow-up-fill"></i> <span class="nav-text">Sinkronisasi SAP</span>
                </a>
            </div>
            
            <div class="p-3 text-center text-secondary small nav-text border-top border-secondary">
                v1.0.0
            </div>
        </div>

        <div id="page-content-wrapper">
            <nav class="navbar navbar-expand-lg bg-primary text-white shadow-sm" id="top-navbar">
                <div class="container-fluid px-4">
                    
                    <button class="btn btn-outline-light border-0 fs-5 d-none d-md-block" id="topNavToggle">
                        <i class="bi bi-text-indent-left"></i>
                    </button>
                    
                    <div class="d-flex align-items-center ms-auto">
                        <div class="form-check form-switch me-4 mb-0">
                            <input class="form-check-input" type="checkbox" role="switch" id="themeToggle">
                            <label class="form-check-label text-white" for="themeToggle"><i class="bi bi-moon-stars-fill"></i></label>
                        </div>
                        
                        <div class="dropdown">
                            <a class="text-white text-decoration-none dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-4 me-2"></i>
                                <span class="fw-bold">Administrator</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Pengaturan</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-box-arrow-right me-2"></i>Keluar</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-4 bg-body-tertiary flex-grow-1">
                @RenderBody()
            </div>
            
            <footer class="bg-white border-top py-3 text-center text-muted small mt-auto" id="main-footer">
                &copy; 2026 - Indofood CBP Noodle Division Cibitung
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', (event) => {
            const sidebarWrapper = document.getElementById('sidebar-wrapper');
            const sidebarToggleArea = document.getElementById('sidebarToggleArea'); // Area Logo/Garis 3
            const topNavToggle = document.getElementById('topNavToggle'); // Tombol Nav Atas

            // --- 1. LOGIKA TOGGLE SUPER APP ---
            const isSidebarCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            if (isSidebarCollapsed) {
                sidebarWrapper.classList.add('collapsed');
            }

            // Fungsi global untuk mengubah status sidebar
            function toggleSidebar() {
                sidebarWrapper.classList.toggle('collapsed');
                const isCollapsedNow = sidebarWrapper.classList.contains('collapsed');
                localStorage.setItem('sidebarCollapsed', isCollapsedNow);
                
                setTimeout(() => {
                    window.dispatchEvent(new Event('resize'));
                }, 300);
            }

            // Pasang trigger klik di area Header Sidebar (Logo / Garis 3)
            sidebarToggleArea.addEventListener('click', toggleSidebar);
            
            // Pasang trigger klik juga di tombol navbar atas
            topNavToggle.addEventListener('click', toggleSidebar);

            // --- 2. LOGIKA DARK MODE ---
            const htmlElement = document.getElementById('html-root');
            const themeToggle = document.getElementById('themeToggle');
            const topNavbar = document.getElementById('top-navbar');
            const footer = document.getElementById('main-footer');

            const currentTheme = localStorage.getItem('theme') || 'light';
            htmlElement.setAttribute('data-bs-theme', currentTheme);
            themeToggle.checked = (currentTheme === 'dark');
            updateColors(currentTheme);

            themeToggle.addEventListener('change', function () {
                const newTheme = this.checked ? 'dark' : 'light';
                htmlElement.setAttribute('data-bs-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                updateColors(newTheme);
            });

            function updateColors(theme) {
                if(theme === 'dark'){
                    topNavbar.classList.replace('bg-primary', 'bg-dark');
                    topNavbar.classList.add('border-secondary');
                    footer.classList.replace('bg-white', 'bg-dark');
                } else {
                    topNavbar.classList.replace('bg-dark', 'bg-primary');
                    topNavbar.classList.remove('border-secondary');
                    footer.classList.replace('bg-dark', 'bg-white');
                }
            }
            
            // --- 3. AUTO-ACTIVE MENU STATE ---
            const currentLocation = window.location.pathname;
            const menuItems = document.querySelectorAll('.sidebar-menu .list-group-item');
            
            menuItems.forEach(item => {
                const itemHref = item.getAttribute('href');
                if (currentLocation === itemHref || (currentLocation.startsWith(itemHref) && itemHref !== '/')) {
                    item.classList.add('active');
                }
            });
        });
    </script>
</body>
</html>