@{
    ViewData["Title"] = "Analitik Performa";
}

<div class="row mb-3 g-2" id="rowBadActors">
    </div>


<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Mode Dimensi Tren</label>
        <select id="dimMode" class="form-select form-select-sm border-primary" onchange="handleModeChange()">
            <option value="Year">Berdasarkan Tahun</option>
            <option value="Month" selected >Berdasarkan Bulan</option>
            <option value="Week">Berdasarkan Minggu</option>
        </select>
    </div>

    <div class="col-md-2 d-none" id="divFltBulan">
        <label class="form-label fw-bold small text-muted mb-1 text-primary">Pilih Bulan</label>
        <select id="fltBulan" class="form-select form-select-sm border-primary" onchange="updateDashboard()">
        </select>
    </div>

    <div class="col-md-2 d-none" id="divFltMinggu">
        <label class="form-label fw-bold small text-muted mb-1 text-primary">Pilih Minggu</label>
        <select id="fltMinggu" class="form-select form-select-sm border-primary" onchange="updateDashboard()">
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Jenis Notifikasi</label>
        <select id="fltNotif" class="form-select form-select-sm" onchange="updateDashboard()">
            <option value="">Semua (NV & NT)</option>
            <option value="NV">NV - DT Lain Lain</option>
            <option value="NT" selected>NT - DT Mesin</option>
        </select>
    </div>
    
    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Regu / Shift</label>
        <select id="fltShift" class="form-select form-select-sm" onchange="updateDashboard()">
            <option value="">Semua Regu (A, B, C)</option>
            <option value="A">Regu A</option>
            <option value="B">Regu B</option>
            <option value="C">Regu C</option>
        </select>
    </div>

    <div class="col-md-2 mb-1">
        <div class="form-check">
            <input class="form-check-input border-danger" type="checkbox" id="chkSteam" onchange="updateDashboard()">
            <label class="form-check-label fw-bold small text-danger" for="chkSteam" style="font-size: 0.8rem;">
                Include Steam Drop
            </label>
        </div>
    </div>
</div>

<div class="row mb-3 g-3 d-print-none animate__animated animate__fadeIn">
    <div class="col-md-4">
        <div class="card bg-danger text-white shadow-sm border-0" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'" onclick="openMTTRDetails()" title="Klik untuk melihat Analitik Mendalam MTTR">
            <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="small fw-bold text-uppercase opacity-75 mb-1" style="font-size: 0.7rem;"><i class="bi bi-tools me-1"></i> Mean Time To Repair (MTTR)</div>
                    <h4 class="mb-0 fw-bold" id="lblMTTR">0 Menit</h4>
                </div>
                <i class="bi bi-stopwatch text-white opacity-50" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white shadow-sm border-0" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'" onclick="openMTBFDetails()" title="Klik untuk melihat Analitik Mendalam MTBF">
            <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="small fw-bold text-uppercase opacity-75 mb-1" style="font-size: 0.7rem;"><i class="bi bi-shield-check me-1"></i> Mean Time Between Failures (MTBF)</div>
                    <h4 class="mb-0 fw-bold" id="lblMTBF">0 Menit</h4>
                </div>
                <i class="bi bi-activity text-white opacity-50" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-primary text-white shadow-sm border-0" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'" onclick="openAvailabilityDetails()" title="Klik untuk melihat Analitik Mendalam Availability">
            <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="small fw-bold text-uppercase opacity-75 mb-1" style="font-size: 0.7rem;"><i class="bi bi-percent me-1"></i> Machine Availability</div>
                    <h4 class="mb-0 fw-bold" id="lblAvailability">0 %</h4>
                </div>
                <i class="bi bi-bar-chart-line text-white opacity-50" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mb-3" style="height: 45vh;">
    <div class="col-12 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-bottom-0 d-flex justify-content-between align-items-center py-2">
                <span class="fw-bold fs-6" id="mainChartTitle">📊 Analitik Downtime vs Jam Terencana</span>
                
                <div class="d-flex align-items-center">
                    <button id="btnReportBuilder" class="btn btn-sm btn-outline-danger fw-bold me-2 shadow-sm" onclick="openReportBuilder()">
                        <i class="bi bi-file-earmark-pdf me-1"></i> Buat Summary Laporan
                    </button>
                    <button id="btnZoomChart" class="btn btn-sm btn-outline-info fw-bold me-3 shadow-sm" onclick="toggleChartZoom()">
                        <i class="bi bi-arrows-angle-expand me-1"></i> Zoom & Scroll
                    </button>

                    <div class="form-check form-switch me-4 mb-0" id="paretoToggleContainer">
                        <input class="form-check-input border-warning" type="checkbox" role="switch" id="chkPareto" onchange="updateDashboard()">
                        <label class="form-check-label fw-bold small text-warning" for="chkPareto">⚠️ Mode Pareto</label>
                    </div>

                    <div id="drillControls" class="d-none animate__animated animate__fadeIn">
                        <div class="btn-group btn-group-sm me-3 shadow-sm" role="group">
                            <input type="radio" class="btn-check" name="drillGroup" id="dgLine" autocomplete="off" checked onchange="changeSubDrillGroup('Line')">
                            <label class="btn btn-outline-primary fw-bold" for="dgLine">Line</label>
                            
                            <input type="radio" class="btn-check" name="drillGroup" id="dgMachine" autocomplete="off" onchange="changeSubDrillGroup('Machine')">
                            <label class="btn btn-outline-primary fw-bold" for="dgMachine">Mesin</label>
                        </div>
                        <button class="btn btn-sm btn-secondary fw-bold shadow-sm" onclick="goBackToMainChart()">
                            <i class="bi bi-arrow-left me-1"></i> Kembali
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="card-body p-2 position-relative" style="overflow-x: auto; overflow-y: hidden;">
                <div id="chartCanvasWrapper" style="min-width: 100%; height: 100%; transition: min-width 0.3s ease;">
                    <canvas id="barChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row" style="height: 40vh;">
    <div class="col-md-7 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-bottom border-warning d-flex justify-content-between align-items-center py-2">
                <span class="fw-bold small">🔍 Rincian Aktivitas: <span id="lblDetail" class="text-primary">Pilih Batang Grafik</span></span>
                
                <div class="btn-group btn-group-sm" role="group">
                    <input type="radio" class="btn-check" name="tableMode" id="tmRaw" autocomplete="off" checked onchange="changeTableMode('Raw')">
                    <label class="btn btn-outline-secondary font-monospace" for="tmRaw">Detail</label>
                    
                    <input type="radio" class="btn-check" name="tableMode" id="tmAgg" autocomplete="off" onchange="changeTableMode('Agg')">
                    <label class="btn btn-outline-secondary font-monospace" for="tmAgg">Agregasi (Frekuensi)</label>
                </div>
            </div>
            <div class="card-body p-0" style="overflow-y: auto;">
                <table class="table table-sm table-hover table-striped mb-0" style="font-size: 0.85rem;" id="mainTable">
                    <thead class="table-dark sticky-top" id="table-header"></thead>
                    <tbody id="table-body">
                        <tr><td colspan="6" class="text-center py-4 text-muted">Klik salah satu titik waktu pada grafik di atas untuk melihat detail.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-5 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-bottom border-primary py-2 d-flex justify-content-between align-items-center">
                <span class="fw-bold small">🍩 Proporsi Downtime per Regu (Menit)</span>
                <button id="btnResetRegu" class="btn btn-sm btn-outline-secondary d-none" style="font-size: 0.7rem; padding: 2px 5px;" onclick="resetReguFilter()">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </button>
            </div>
            <div class="card-body p-2" style="position: relative; flex-grow: 1; min-height: 0;">
                <canvas id="pieChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/chartjs/chart.min.js"></script>
<script src="~/lib/chartjs/chartjs-plugin-datalabels.min.js"></script>
<script src="~/lib/html2canvas.min.js"></script>
<script src="~/lib/jspdf.umd.min.js"></script>

<style>
    .animate__fadeIn { animation: fadeIn 0.3s; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .bad-actor-card { transition: transform 0.2s; cursor: pointer; }
    .bad-actor-card:hover { transform: translateY(-2px); }
    .drill-link { 
        cursor: pointer; 
        text-decoration: underline; 
        text-decoration-style: dotted; 
        transition: opacity 0.2s;
    }
    .drill-link:hover { opacity: 0.7; }
</style>

<!-- REPORT BUILDER MODAL -->
<div class="modal fade" id="modalReportBuilder" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white py-2">
                <h5 class="modal-title fs-6"><i class="bi bi-file-earmark-pdf me-1"></i> Konfigurasi Laporan PDF</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-3">
                <p class="small text-muted mb-3">Pilih komponen yang ingin dicetak ke dalam laporan. Data akan diproses sesuai filter yang Anda tentukan tanpa mengambil ulang dari server.</p>
                <div class="list-group list-group-flush small">
                    <div class="list-group-item px-0 py-2">
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" checked disabled id="chkRepMain">
                            <label class="form-check-label fw-bold" for="chkRepMain">Grafik Utama (Downtime vs Terencana)</label>
                        </div>
                        <div class="text-muted ms-4" style="font-size: 0.75rem;">(Wajib, mengikuti filter tampilan saat ini)</div>
                    </div>
                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="chkRepTrend" onchange="toggleRepFilter('RepTrend')">
                                <label class="form-check-label" for="chkRepTrend">Grafik Analitik Sekunder (Run Chart)</label>
                            </div>
                        </div>
                        <div id="fltRepTrendWrapper" class="ms-4 mt-2 d-none">
                            <select id="fltRepTrendMode" class="form-select form-select-sm mb-1" style="font-size: 0.75rem;" onchange="updateRepFilterDdl('RepTrend')">
                                <option value="SYNC">Sesuai Filter Dashboard (Sync)</option>
                                <option value="ALL">Semua Waktu (All Time)</option>
                                <option value="MONTH">Pilih Bulan Khusus</option>
                                <option value="WEEK">Pilih Minggu Khusus</option>
                            </select>
                            <select id="fltRepTrendMonth" class="form-select form-select-sm mb-1 d-none" style="font-size: 0.75rem;"></select>
                            <select id="fltRepTrendWeek" class="form-select form-select-sm d-none" style="font-size: 0.75rem;"></select>
                        </div>
                    </div>
                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="chkRepPie" onchange="toggleRepFilter('RepPie')">
                                <label class="form-check-label" for="chkRepPie">Proporsi Downtime per Regu (Pie Chart)</label>
                            </div>
                        </div>
                        <div id="fltRepPieWrapper" class="ms-4 mt-2 d-none">
                            <select id="fltRepPieMode" class="form-select form-select-sm mb-1" style="font-size: 0.75rem;" onchange="updateRepFilterDdl('RepPie')">
                                <option value="SYNC">Sesuai Filter Dashboard (Sync)</option>
                                <option value="ALL">Semua Waktu (All Time)</option>
                                <option value="MONTH">Pilih Bulan Khusus</option>
                                <option value="WEEK">Pilih Minggu Khusus</option>
                            </select>
                            <select id="fltRepPieMonth" class="form-select form-select-sm mb-1 d-none" style="font-size: 0.75rem;"></select>
                            <select id="fltRepPieWeek" class="form-select form-select-sm d-none" style="font-size: 0.75rem;"></select>
                        </div>
                    </div>
                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="chkRepLine" onchange="toggleRepFilter('RepLine')">
                                <label class="form-check-label" for="chkRepLine">Grafik Batang Downtime by Line</label>
                            </div>
                        </div>
                        <div id="fltRepLineWrapper" class="ms-4 mt-2 d-none">
                            <select id="fltRepLineMode" class="form-select form-select-sm mb-1" style="font-size: 0.75rem;" onchange="updateRepFilterDdl('RepLine')">
                                <option value="SYNC">Sesuai Filter Dashboard (Sync)</option>
                                <option value="ALL">Semua Waktu (All Time)</option>
                                <option value="MONTH">Pilih Bulan Khusus</option>
                                <option value="WEEK">Pilih Minggu Khusus</option>
                            </select>
                            <select id="fltRepLineMonth" class="form-select form-select-sm mb-1 d-none" style="font-size: 0.75rem;"></select>
                            <select id="fltRepLineWeek" class="form-select form-select-sm d-none" style="font-size: 0.75rem;"></select>
                        </div>
                    </div>
                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="chkRepMachine" onchange="toggleRepFilter('RepMachine')">
                                <label class="form-check-label" for="chkRepMachine">Grafik Batang Downtime by Mesin</label>
                            </div>
                        </div>
                        <div id="fltRepMachineWrapper" class="ms-4 mt-2 d-none">
                            <select id="fltRepMachineMode" class="form-select form-select-sm mb-1" style="font-size: 0.75rem;" onchange="updateRepFilterDdl('RepMachine')">
                                <option value="SYNC">Sesuai Filter Dashboard (Sync)</option>
                                <option value="ALL">Semua Waktu (All Time)</option>
                                <option value="MONTH">Pilih Bulan Khusus</option>
                                <option value="WEEK">Pilih Minggu Khusus</option>
                            </select>
                            <select id="fltRepMachineMonth" class="form-select form-select-sm mb-1 d-none" style="font-size: 0.75rem;"></select>
                            <select id="fltRepMachineWeek" class="form-select form-select-sm d-none" style="font-size: 0.75rem;"></select>
                        </div>
                    </div>
                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="chkRepMTTRBF" onchange="toggleRepFilter('RepMTTRBF')">
                                <label class="form-check-label" for="chkRepMTTRBF">Kesimpulan Kehandalan (MTTR, MTBF, Availability)</label>
                            </div>
                        </div>
                        <div id="fltRepMTTRBFWrapper" class="ms-4 mt-2 d-none">
                            <select id="fltRepMTTRBFMode" class="form-select form-select-sm mb-1" style="font-size: 0.75rem;" onchange="updateRepFilterDdl('RepMTTRBF')">
                                <option value="SYNC">Sesuai Filter Dashboard (Sync)</option>
                                <option value="ALL">Semua Waktu (All Time)</option>
                                <option value="MONTH">Pilih Bulan Khusus</option>
                                <option value="WEEK">Pilih Minggu Khusus</option>
                            </select>
                            <select id="fltRepMTTRBFMonth" class="form-select form-select-sm mb-1 d-none" style="font-size: 0.75rem;"></select>
                            <select id="fltRepMTTRBFWeek" class="form-select form-select-sm d-none" style="font-size: 0.75rem;"></select>
                        </div>
                    </div>
                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="chkRepTopBadActor" onchange="toggleRepFilter('RepTopBadActor')">
                                <label class="form-check-label" for="chkRepTopBadActor">Tabel Top 5 Bad Actor (Downtime Tertinggi)</label>
                            </div>
                        </div>
                        <div id="fltRepTopBadActorWrapper" class="ms-4 mt-2 d-none">
                            <select id="fltRepTopBadActorMode" class="form-select form-select-sm mb-1" style="font-size: 0.75rem;" onchange="updateRepFilterDdl('RepTopBadActor')">
                                <option value="SYNC">Sesuai Filter Dashboard (Sync)</option>
                                <option value="ALL">Semua Waktu (All Time)</option>
                                <option value="MONTH">Pilih Bulan Khusus</option>
                                <option value="WEEK">Pilih Minggu Khusus</option>
                            </select>
                            <select id="fltRepTopBadActorMonth" class="form-select form-select-sm mb-1 d-none" style="font-size: 0.75rem;"></select>
                            <select id="fltRepTopBadActorWeek" class="form-select form-select-sm d-none" style="font-size: 0.75rem;"></select>
                        </div>
                    </div>
                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="chkRepActivity" onchange="toggleRepFilter('RepActivity')">
                                <label class="form-check-label" for="chkRepActivity">Tabel Rincian Aktifitas Downtime</label>
                            </div>
                        </div>
                        <div id="fltRepActivityWrapper" class="ms-4 mt-2 d-none">
                            <select id="fltRepActivityMode" class="form-select form-select-sm mb-1" style="font-size: 0.75rem;" onchange="updateRepFilterDdl('RepActivity')">
                                <option value="SYNC">Sesuai Filter Dashboard (Sync)</option>
                                <option value="ALL">Semua Waktu (All Time)</option>
                                <option value="MONTH">Pilih Bulan Khusus</option>
                                <option value="WEEK">Pilih Minggu Khusus</option>
                            </select>
                            <select id="fltRepActivityMonth" class="form-select form-select-sm mb-1 d-none" style="font-size: 0.75rem;"></select>
                            <select id="fltRepActivityWeek" class="form-select form-select-sm d-none" style="font-size: 0.75rem;"></select>
                        </div>
                    </div>
                    <div class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="chkRepOpenFindings">
                                <label class="form-check-label text-danger fw-bold" for="chkRepOpenFindings">Tabel Daftar Temuan (Status OPEN)</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-sm btn-danger fw-bold" onclick="generatePDF()"><i class="bi bi-printer me-1"></i> Buat Laporan</button>
            </div>
        </div>
    </div>
</div>

<!-- HIDDEN PDF CONTAINER -->
<div id="pdf-container" style="position: absolute; left: -9999px; top: 0; width: 794px; background: white; padding: 20px; font-family: 'Segoe UI', Arial, sans-serif; box-sizing: border-box; z-index: -1;">
    <div id="pdf-header" style="border-bottom: 2px solid #dc3545; padding-bottom: 10px; margin-bottom: 20px;">
        <h2 style="margin: 0; color: #333; font-size: 24px;">Laporan Analitik Dashboard Teknik</h2>
        <p style="margin: 5px 0 0; color: #666; font-size: 14px;" id="pdf-timestamp"></p>
    </div>
    
    <div id="pdf-content-area" style="width: 100%;">
        <!-- Charts will be injected here -->
    </div>
    
    <div id="pdf-footer" style="margin-top: 30px; border-top: 1px solid #ccc; padding-top: 10px; text-align: center; font-size: 10px; color: #999;">
        Dihasilkan secara otomatis oleh Sistem Dashboard Teknik P1
    </div>
</div>

<!-- FULL SCREEN LOADING OVERLAY -->
<div id="pdf-loading-overlay" class="d-none" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(255,255,255,0.9); z-index: 9999; flex-direction: column; justify-content: center; align-items: center;">
    <div class="spinner-border text-danger mb-3" style="width: 3rem; height: 3rem;" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <h4 class="text-dark fw-bold mb-1">Membangun Laporan PDF</h4>
    <p class="text-muted small">Sedang merender grafik, mohon tunggu sebentar...</p>
</div>

<div class="modal fade" id="modalMTTR" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-top border-4 border-danger">
            <div class="modal-header bg-light py-2">
                <h5 class="modal-title fw-bold text-danger"><i class="bi bi-tools me-2"></i> Deep Dive Analytics: MTTR (Kecepatan Perbaikan)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-body-tertiary">
                <div class="row g-3">
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-header bg-white py-2 fw-bold small text-muted" id="headerChartMTTR">Tren MTTR Historis</div>
                            <div class="card-body p-2" style="height: 250px;">
                                <canvas id="chartMTTR"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-white py-2 fw-bold small text-muted">Top 10 Breakdown Terlama (Menarik Nilai Rata-rata)</div>
                            <div class="card-body p-0 table-responsive">
                                <table class="table table-sm table-striped table-hover align-middle mb-0" style="font-size: 0.85rem;">
