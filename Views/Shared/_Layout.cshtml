<!DOCTYPE html>
<html lang="en" id="html-root" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dashboard Teknik P1</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Sedikit penyesuaian untuk transisi pergantian warna agar lebih halus */
        body { transition: background-color 0.3s ease, color 0.3s ease; }
        .navbar { transition: background-color 0.3s ease; }
    </style>
</head>
<body class="bg-body-tertiary">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4 shadow-sm" id="main-navbar">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold d-flex flex-column align-items-start" href="/">
                    <img src="~/images/logo_indofood.svg" alt="Logo Indofood CBP" height="35" class="mb-1">
                    <span class="fs-6 text-warning" style="letter-spacing: 1px;">DASHBOARD TEKNIK P1</span>
                </a>
                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/">Home (Performance)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Temuan">Log Temuan (Field)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Upload">Staging Area (Upload)</a>
                        </li>
                    </ul>
                    
                    <div class="form-check form-switch me-4">
                        <input class="form-check-input" type="checkbox" role="switch" id="themeToggle">
                        <label class="form-check-label text-white" for="themeToggle">🌙 Mode Gelap</label>
                    </div>

                    <span class="navbar-text text-white">
                        User: Administrator
                    </span>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top mt-5 py-3 text-center text-body-secondary">
        <div class="container">
            &copy; 2026 - Technical Production Noodle Division Cibitung
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', (event) => {
            const htmlElement = document.getElementById('html-root');
            const themeToggle = document.getElementById('themeToggle');
            const navbar = document.getElementById('main-navbar');

            // Cek apakah user sebelumnya sudah memilih dark mode
            const currentTheme = localStorage.getItem('theme') || 'light';
            
            // Terapkan tema saat halaman pertama kali dimuat
            htmlElement.setAttribute('data-bs-theme', currentTheme);
            themeToggle.checked = (currentTheme === 'dark');
            updateNavbarColor(currentTheme);

            // Event listener saat toggle digeser
            themeToggle.addEventListener('change', function () {
                const newTheme = this.checked ? 'dark' : 'light';
                htmlElement.setAttribute('data-bs-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                updateNavbarColor(newTheme);
            });

            // Opsional: Mengubah warna Navbar agar lebih menyatu dengan Dark Mode
            function updateNavbarColor(theme) {
                if(theme === 'dark'){
                    navbar.classList.remove('bg-primary');
                    navbar.classList.add('bg-dark');
                } else {
                    navbar.classList.remove('bg-dark');
                    navbar.classList.add('bg-primary');
                }
            }
        });
    </script>
</body>
</html>