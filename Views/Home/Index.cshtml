@{
    ViewData["Title"] = "Analitik Performa";
}

<div class="row mb-3 g-2" id="rowBadActors">
    </div>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Mode Dimensi Tren</label>
        <select id="dimMode" class="form-select form-select-sm border-primary" onchange="handleModeChange()">
            <option value="Year">Berdasarkan Tahun</option>
            <option value="Month">Berdasarkan Bulan</option>
            <option value="Week">Berdasarkan Minggu</option>
        </select>
    </div>

    <div class="col-md-2 d-none" id="divFltBulan">
        <label class="form-label fw-bold small text-muted mb-1 text-primary">Pilih Bulan</label>
        <select id="fltBulan" class="form-select form-select-sm border-primary" onchange="updateDashboard()">
        </select>
    </div>

    <div class="col-md-2 d-none" id="divFltMinggu">
        <label class="form-label fw-bold small text-muted mb-1 text-primary">Pilih Minggu</label>
        <select id="fltMinggu" class="form-select form-select-sm border-primary" onchange="updateDashboard()">
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Jenis Notifikasi</label>
        <select id="fltNotif" class="form-select form-select-sm" onchange="updateDashboard()">
            <option value="">Semua (NV & NT)</option>
            <option value="NV">NV - DT Lain Lain</option>
            <option value="NT">NT - DT Mesin</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Regu / Shift</label>
        <select id="fltShift" class="form-select form-select-sm" onchange="updateDashboard()">
            <option value="">Semua Regu (A, B, C)</option>
            <option value="A">Regu A</option>
            <option value="B">Regu B</option>
            <option value="C">Regu C</option>
        </select>
    </div>

    <div class="col-md-2 mb-1">
        <div class="form-check">
            <input class="form-check-input border-danger" type="checkbox" id="chkSteam" checked onchange="updateDashboard()">
            <label class="form-check-label fw-bold small text-danger" for="chkSteam" style="font-size: 0.8rem;">
                Include Steam Drop
            </label>
        </div>
    </div>
</div>

<div class="row mb-3" style="height: 45vh;">
    <div class="col-12 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-bottom-0 d-flex justify-content-between align-items-center py-2">
                <span class="fw-bold fs-6" id="mainChartTitle">📊 Analitik Downtime vs Jam Terencana</span>
                
                <div class="d-flex align-items-center">
                    <div class="form-check form-switch me-4 mb-0" id="paretoToggleContainer">
                        <input class="form-check-input border-warning" type="checkbox" role="switch" id="chkPareto" onchange="updateDashboard()">
                        <label class="form-check-label fw-bold small text-warning" for="chkPareto">⚠️ Mode Pareto (80/20)</label>
                    </div>

                    <div id="drillControls" class="d-none animate__animated animate__fadeIn">
                        <div class="btn-group btn-group-sm me-3 shadow-sm" role="group">
                            <input type="radio" class="btn-check" name="drillGroup" id="dgLine" autocomplete="off" checked onchange="changeSubDrillGroup('Line')">
                            <label class="btn btn-outline-primary fw-bold" for="dgLine">Berdasarkan Line</label>
                            
                            <input type="radio" class="btn-check" name="drillGroup" id="dgMachine" autocomplete="off" onchange="changeSubDrillGroup('Machine')">
                            <label class="btn btn-outline-primary fw-bold" for="dgMachine">Berdasarkan Mesin</label>
                        </div>
                        <button class="btn btn-sm btn-secondary fw-bold shadow-sm" onclick="goBackToMainChart()">
                            <i class="bi bi-arrow-left me-1"></i> Kembali
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="card-body p-2 position-relative">
                <canvas id="barChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row" style="height: 40vh;">
    <div class="col-md-7 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-bottom border-warning d-flex justify-content-between align-items-center py-2">
                <span class="fw-bold small">🔍 Rincian Aktivitas: <span id="lblDetail" class="text-primary">Pilih Batang Grafik</span></span>
                
                <div class="btn-group btn-group-sm" role="group">
                    <input type="radio" class="btn-check" name="tableMode" id="tmRaw" autocomplete="off" checked onchange="changeTableMode('Raw')">
                    <label class="btn btn-outline-secondary font-monospace" for="tmRaw">Detail</label>
                    
                    <input type="radio" class="btn-check" name="tableMode" id="tmAgg" autocomplete="off" onchange="changeTableMode('Agg')">
                    <label class="btn btn-outline-secondary font-monospace" for="tmAgg">Agregasi (Frekuensi)</label>
                </div>
            </div>
            <div class="card-body p-0" style="overflow-y: auto;">
                <table class="table table-sm table-hover table-striped mb-0" style="font-size: 0.85rem;" id="mainTable">
                    <thead class="table-dark sticky-top" id="table-header"></thead>
                    <tbody id="table-body">
                        <tr><td colspan="6" class="text-center py-4 text-muted">Klik salah satu titik waktu pada grafik di atas untuk melihat detail.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-5 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-bottom border-primary py-2">
                <span class="fw-bold small">🍩 Proporsi Downtime per Regu (Menit)</span>
            </div>
            <div class="card-body p-2" style="position: relative; flex-grow: 1; min-height: 0;">
                <canvas id="pieChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>

<style>
    .animate__fadeIn { animation: fadeIn 0.3s; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .bad-actor-card { transition: transform 0.2s; cursor: pointer; }
    .bad-actor-card:hover { transform: translateY(-2px); }
</style>

<script>
    Chart.register(ChartDataLabels);

    const ypDataRaw = @Html.Raw(ViewBag.DetailsJson);
    const yrDataRaw = @Html.Raw(ViewBag.Yr21Json);

    let barChartInst = null;
    let pieChartInst = null;
    
    let topLevelAgg = {}; 
    let chartLevel = 0; 
    let selectedTimeLabel = "";
    let selectedTimeKey = ""; // VARIABEL BARU: Menyimpan kunci asli (YYYY-MM-DD)
    let subDrillMode = "Line"; 
    let currentTableMode = "Raw"; 
    let currentFilteredData = [];

    let currentDrillDownData = [];
    let sortState = { col: -1, asc: true };

    const monthNames = ["Jan", "Feb", "Mar", "Apr", "Mei", "Jun", "Jul", "Ags", "Sep", "Okt", "Nov", "Des"];
    const dayNames = ["Minggu", "Senin", "Selasa", "Rabu", "Kamis", "Jumat", "Sabtu"];
    
    // --- PEMANTAU TEMA DARK MODE ---
    const themeObserver = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.attributeName === "data-bs-theme") {
                if (barChartInst) barChartInst.update();
                if (pieChartInst) pieChartInst.update();
            }
        });
    });
    themeObserver.observe(document.documentElement, { attributes: true });

    // Fungsi pembantu pendeteksi warna
    const getChartLabelColor = () => document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#f8f9fa' : '#333';
    const getGridColor = () => document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)';
    
    document.addEventListener("DOMContentLoaded", () => {
        populateDynamicDropdowns();
        handleModeChange(); 
    });

    function getLineName(funcLoc) {
        if (!funcLoc) return "-";
        let parts = funcLoc.split('-');
        if (parts.length >= 4) return "Line " + Number(parts[3]); 
        return "-";
    }

    function getMachineName(funcLoc, activityText) {
        if (!funcLoc) return "-";
        let kodeMesin = funcLoc.slice(-3);
        let txt = activityText ? activityText.toLowerCase() : "";
        if (kodeMesin === "001") return "Alkali";
        if (kodeMesin === "002") return "Mixer";
        if (kodeMesin === "003") return "Feeder";
        if (kodeMesin === "004") return "Press";
        if (kodeMesin === "005") {
            if (txt.includes("tekanan") || txt.includes("drop") || txt.includes("bar") || txt.includes("dibawah") || txt.includes("di bawah") || txt.includes("turun") || txt.includes("kurang")) return "Boiler";
            return "Steambox";
        }
        if (kodeMesin === "006") return "Cutter & Distributor";
        if (kodeMesin === "007") return "Fryer";
        if (kodeMesin === "008") return "Cooler";
        if (kodeMesin === "009") {
            if (txt.includes("autoloader") || txt.includes("auto loader") || txt.includes("bumbu") || txt.includes("minyak")) return "Autoloader";
            return "Wrapper";
        }
        return funcLoc; 
    }

    function populateDynamicDropdowns() {
        const ddlBulan = document.getElementById("fltBulan");
        const ddlMinggu = document.getElementById("fltMinggu");
        let bulanSet = new Set(), mingguSet = new Set();
        ypDataRaw.forEach(item => {
            let d = new Date(item.NotificationDate);
            if(d.getFullYear() > 1900) {
                bulanSet.add(JSON.stringify({ val: `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`, text: d.toLocaleDateString('id-ID', { month: 'long', year: 'numeric' }) }));
            }
            if (item.WeekKalendarIndofood) mingguSet.add(item.WeekKalendarIndofood);
        });
        Array.from(bulanSet).map(x => JSON.parse(x)).sort((a, b) => b.val.localeCompare(a.val)).forEach(item => ddlBulan.innerHTML += `<option value="${item.val}">${item.text}</option>`);
        Array.from(mingguSet).sort((a, b) => b.localeCompare(a)).forEach(w => ddlMinggu.innerHTML += `<option value="${w}">Week ${w}</option>`);
    }

    function handleModeChange() {
        const mode = document.getElementById("dimMode").value;
        document.getElementById("divFltBulan").classList.toggle("d-none", mode !== "Month");
        document.getElementById("divFltMinggu").classList.toggle("d-none", mode !== "Week");
        updateDashboard(); 
    }

    function goBackToMainChart() {
        chartLevel = 0;
        document.getElementById('drillControls').classList.add('d-none');
        document.getElementById('paretoToggleContainer').classList.remove('d-none');
        document.getElementById('mainChartTitle').innerText = "📊 Analitik Downtime vs Jam Terencana";
        document.getElementById('lblDetail').innerText = "Pilih Batang Grafik";
        document.getElementById('table-body').innerHTML = `<tr><td colspan="6" class="text-center py-4 text-muted">Klik salah satu batang grafik di atas untuk melihat detail.</td></tr>`;
        updateDashboard(true); 
    }

    function changeSubDrillGroup(mode) {
        subDrillMode = mode;
        renderSubChart();
    }

    function changeTableMode(mode) {
        currentTableMode = mode;
        renderTableRows();
    }

    function updateDashboard(isBackwards = false) {
        if(!isBackwards && chartLevel === 1) {
            chartLevel = 0;
            document.getElementById('drillControls').classList.add('d-none');
            document.getElementById('paretoToggleContainer').classList.remove('d-none');
            document.getElementById('mainChartTitle').innerText = "📊 Analitik Downtime vs Jam Terencana";
            document.getElementById('lblDetail').innerText = "Pilih Batang Grafik";
        }

        const mode = document.getElementById("dimMode").value;
        const fltNotif = document.getElementById("fltNotif").value;
        const fltShift = document.getElementById("fltShift").value;
        const selMonth = document.getElementById("fltBulan").value;
        const selWeek = document.getElementById("fltMinggu").value;
        const isSteamIncluded = document.getElementById("chkSteam").checked;
        const isParetoMode = document.getElementById("chkPareto").checked;

        const isTimeMatch = (dateObj, weekStr) => {
            if (mode === "Month") return `${dateObj.getFullYear()}-${String(dateObj.getMonth() + 1).padStart(2, '0')}` === selMonth;
            if (mode === "Week") return weekStr === selWeek;
            return true;
        };

        const ypFiltered = ypDataRaw.filter(item => {
            let mNotif = !fltNotif || (item.NotificationType && item.NotificationType.includes(fltNotif));
            let mShift = !fltShift || (item.WageGroup_GroupShift && item.WageGroup_GroupShift.includes(fltShift));
            let mTime = isTimeMatch(new Date(item.NotificationDate), item.WeekKalendarIndofood);
            let mBoiler = !(getMachineName(item.FunctionLocation, item.ActivityText) === "Boiler" && !isSteamIncluded);
            return mNotif && mShift && mTime && mBoiler;
        });
        currentFilteredData = ypFiltered;

        calculateTopBadActors(ypFiltered);

        let yrAgg = {};
        yrDataRaw.forEach(item => {
            let d = new Date(item.PostingDate);
            if (fltShift && (!item.WageGroup || !item.WageGroup.includes(fltShift))) return;
            if (!isTimeMatch(d, item.WeekOfBasicFinishedDate)) return;
            
            // PERBAIKAN: Masukkan item.WeekOfBasicFinishedDate
            let key = getGroupingKey(d, mode, item.WeekOfBasicFinishedDate);
            
            if (!yrAgg[key]) yrAgg[key] = 0;
            yrAgg[key] += (item.PlannedHour * 60); 
        });

        let ypAgg = {};
        ypFiltered.forEach(item => {
            // PERBAIKAN: Masukkan item.WeekKalendarIndofood
            let key = getGroupingKey(new Date(item.NotificationDate), mode, item.WeekKalendarIndofood);
            
            if (!ypAgg[key]) ypAgg[key] = { mins: 0, items: [] };
            ypAgg[key].mins += item.TotalDownTimeInMinutes;
            ypAgg[key].items.push(item);
        });

        topLevelAgg = ypAgg;
        let rawKeys = Object.keys(ypAgg);
        
        if (isParetoMode) {
            rawKeys.sort((a, b) => ypAgg[b].mins - ypAgg[a].mins);
        } else {
            rawKeys.sort((a, b) => {
                if (mode === "Year") return monthNames.indexOf(a) - monthNames.indexOf(b);
                if (mode === "Week") return a.localeCompare(b);
                
                // PERBAIKAN: Logika khusus untuk mode Bulan (Week 1, Week 2, dst)
                if (mode === "Month") {
                    // Ekstrak angka dari teks (misal "Week 12" menjadi angka 12)
                    let numA = parseInt(a.replace(/\D/g, '')) || 0;
                    let numB = parseInt(b.replace(/\D/g, '')) || 0;
                    return numA - numB;
                }
                
                return a.localeCompare(b);
            });
        }

        let labels = [], percentData = [], minuteData = [], targetLine = [];
        let totalMinsAll = rawKeys.reduce((sum, k) => sum + ypAgg[k].mins, 0);
        let cumulativeMins = 0;
        let paretoLineData = [];
        let actualKeys = []; // Array kunci asli

        rawKeys.forEach(k => {
            actualKeys.push(k);
            
            // PERBAIKAN: Memoles nama label menjadi tanggal cantik untuk sumbu X
            if (mode === "Week") {
                let dTemp = new Date(k);
                labels.push(`${dayNames[dTemp.getDay()]}, ${dTemp.toLocaleDateString('id-ID', {day: '2-digit', month: 'short'})}`);
            } else {
                labels.push(k);
            }

            let dtMins = ypAgg[k].mins;            
            let plannedMins = yrAgg[k] || 0;       
            minuteData.push(dtMins);
            percentData.push(plannedMins > 0 ? ((dtMins / plannedMins) * 100).toFixed(2) : 0);
            targetLine.push(1.5);

            cumulativeMins += dtMins;
            let cumPercent = totalMinsAll > 0 ? (cumulativeMins / totalMinsAll) * 100 : 0;
            paretoLineData.push(cumPercent.toFixed(1));
        });

        if (isParetoMode) {
            renderParetoChart(labels, minuteData, paretoLineData, actualKeys);
        } else {
            renderTopChart(labels, percentData, minuteData, targetLine, actualKeys);
        }
        
        updatePieChart(ypFiltered);
    }

    // PERBAIKAN FUNGSI GROUPING KEY
    function getGroupingKey(d, mode, sapWeekStr) {
        if (mode === "Year") return monthNames[d.getMonth()]; 
        
        if (mode === "Month") {
            // Jika data SAP mengirimkan kode minggu (misal: "202601" atau "202612")
            if (sapWeekStr && sapWeekStr.length >= 6) {
                // Ambil 2 digit terakhir dan jadikan angka (agar "01" jadi "1")
                let weekNum = parseInt(sapWeekStr.slice(-2), 10);
                return "Week " + weekNum;
            }
            // Fallback aman jika data SAP kosong
            return "Minggu Ke-" + Math.ceil(d.getDate() / 7); 
        }
        
        if (mode === "Week") {
            return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
        }
        return "Lainnya";
    }

    function calculateTopBadActors(filteredData) {
        let machineMap = {};
        filteredData.forEach(item => {
            let line = getLineName(item.FunctionLocation);
            let machine = getMachineName(item.FunctionLocation, item.ActivityText);
            let nameKey = `${line} - ${machine}`;
            if (!machineMap[nameKey]) machineMap[nameKey] = 0;
            machineMap[nameKey] += item.TotalDownTimeInMinutes;
        });

        let sortedActors = Object.keys(machineMap).map(k => ({ name: k, mins: machineMap[k] }))
                                 .sort((a,b) => b.mins - a.mins).slice(0, 5);

        const container = document.getElementById("rowBadActors");
        if(sortedActors.length === 0) {
            container.innerHTML = `<div class="col-12"><div class="alert alert-info py-2 small mb-0 text-center">💡 Tidak ada data downtime pada filter periode ini.</div></div>`;
            return;
        }

        let html = `<div class="col-12"><span class="badge bg-danger mb-1 fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> TOP 5 BAD ACTORS PERIODIK :</span></div>`;
        const colors = ["border-danger text-danger", "border-warning text-warning", "border-primary text-primary", "border-success text-success", "border-secondary text-secondary"];
        
        sortedActors.forEach((actor, i) => {
            html += `
                <div class="col shadow-sm">
                    <div class="card bad-actor-card h-100 border-start border-4 ${colors[i % 5]} bg-white" onclick="filterTableByBadActor('${actor.name}')" title="Klik untuk melihat rincian kerusakan">
                        <div class="card-body py-1 px-2 d-flex align-items-center justify-content-between">
                            <div class="text-truncate" style="max-width: 80%;">
                                <span class="fw-bold small d-block text-dark">${actor.name}</span>
                            </div>
                            <span class="badge bg-dark fw-bold">${actor.mins} m</span>
                        </div>
                    </div>
                </div>`;
        });
        container.innerHTML = html;
    }

    function filterTableByBadActor(actorName) {
        // Saring data dari memori global khusus untuk mesin yang diklik
        let specificItems = currentFilteredData.filter(item => {
            let line = getLineName(item.FunctionLocation);
            let machine = getMachineName(item.FunctionLocation, item.ActivityText);
            let currentName = `${line} - ${machine}`;
            return currentName === actorName;
        });

        // Lempar datanya ke tabel bawah
        loadDrillDownTable(`🚨 Investigasi Bad Actor ➔ ${actorName}`, specificItems);

        // UX Ekstra: Gulir otomatis layar ke arah tabel secara halus
        document.getElementById('lblDetail').scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // PERBAIKAN: Menambahkan parameter actualKeys ke Chart
    function renderTopChart(labels, pctData, minData, targetLine, actualKeys) {
        const ctx = document.getElementById('barChart').getContext('2d');
        if (barChartInst) barChartInst.destroy();

        barChartInst = new Chart(ctx, {
            // PERUBAHAN UTAMA: Ubah dasar grafik menjadi 'line'
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    { 
                        type: 'line', 
                        label: 'Standar (1.5%)', 
                        data: targetLine, 
                        borderColor: 'rgba(220, 53, 69, 1)', 
                        borderWidth: 2, 
                        borderDash: [5, 5], 
                        pointRadius: 0, 
                        fill: false, 
                        datalabels: { display: false } 
                    },
                    { 
                        // PERUBAHAN TAMPILAN: Run Chart dengan efek Area Fill
                        type: 'line', 
                        label: 'Downtime (%)', 
                        data: pctData, 
                        backgroundColor: 'rgba(54, 162, 235, 0.2)', // Biru transparan untuk area bawah garis
                        borderColor: 'rgba(54, 162, 235, 1)', 
                        borderWidth: 2, 
                        pointBackgroundColor: 'rgba(54, 162, 235, 1)',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 1,
                        pointRadius: 4, 
                        pointHoverRadius: 6,
                        fill: true, // Memicu efek Area Chart
                        tension: 0.1, // Sedikit melengkungkan garis agar terlihat luwes tapi tetap akurat
                        customMinutes: minData 
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    datalabels: { 
                        anchor: 'end', 
                        align: 'top', 
                        offset: 4, // Jarak teks dari titik agar tidak menabrak garis
                        color: getChartLabelColor, 
                        font: { weight: 'bold', size: 10 }, 
                        formatter: function(v, ctx) { 
                            return ctx.dataset.label === 'Standar (1.5%)' ? null : `${v}% \n(${ctx.dataset.customMinutes[ctx.dataIndex]} m)`; 
                        }, 
                        textAlign: 'center' 
                    }
                },
                scales: { 
                    y: { 
                        beginAtZero: true, 
                        suggestedMax: 3,
                        title: { display: true, text: 'Persentase Downtime (%)' }
                    } 
                },
                onClick: (e, elements) => { 
                    if (elements.length > 0) { 
                        const idx = elements[0].index; 
                        
                        selectedTimeLabel = labels[idx]; 
                        selectedTimeKey = actualKeys[idx]; 
                        
                        chartLevel = 1; 
                        document.getElementById('drillControls').classList.remove('d-none'); 
                        document.getElementById('paretoToggleContainer').classList.add('d-none'); 
                        document.getElementById('mainChartTitle').innerHTML = `📊 Rincian Periode: <span class="text-primary">${selectedTimeLabel}</span>`; 
                        
                        renderSubChart(); 
                        loadDrillDownTable(`Periode: ${selectedTimeLabel}`, topLevelAgg[selectedTimeKey].items); 
                    } 
                }
            }
        });
    }

    // PERBAIKAN: Menambahkan parameter actualKeys ke Chart
    function renderParetoChart(labels, minData, cumPctData, actualKeys) {
        const ctx = document.getElementById('barChart').getContext('2d');
        if (barChartInst) barChartInst.destroy();

        barChartInst = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    { type: 'line', label: '% Kumulatif', data: cumPctData, borderColor: 'rgba(220, 53, 69, 1)', backgroundColor: 'rgba(220, 53, 69, 0.1)', borderWidth: 2, pointRadius: 4, yAxisID: 'yPareto', fill: false, datalabels: { anchor: 'bottom', align: 'top', formatter: v => `${v}%`, color: getChartLabelColor, font: { size: 9 } } },
                    { type: 'bar', label: 'Downtime (Menit)', data: minData, backgroundColor: 'rgba(153, 102, 255, 0.7)', borderColor: 'rgba(153, 102, 255, 1)', borderWidth: 1, borderRadius: 4, yAxisID: 'yMins', customMinutes: minData }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    datalabels: { formatter: (v, c) => c.dataset.type === 'line' ? `${v}%` : `${v}m`, font: { weight: 'bold', size: 10 } }
                },
                scales: { 
                    yMins: { type: 'linear', position: 'left', title: { display: true, text: 'Durasi (Menit)' }, beginAtZero: true },
                    yPareto: { type: 'linear', position: 'right', title: { display: true, text: 'Persentase Kumulatif (%)' }, min: 0, max: 105, grid: { drawOnChartArea: false }, ticks: { callback: v => `${v}%` } }
                },
                onClick: (e, elements) => { 
                    if (elements.length > 0) { 
                        const idx = elements[0].index; 
                        selectedTimeLabel = labels[idx]; 
                        selectedTimeKey = actualKeys[idx]; 
                        
                        chartLevel = 1; 
                        document.getElementById('drillControls').classList.remove('d-none'); 
                        document.getElementById('paretoToggleContainer').classList.add('d-none'); 
                        document.getElementById('mainChartTitle').innerHTML = `📊 Rincian Periode: <span class="text-primary">${selectedTimeLabel}</span>`; 
                        
                        renderSubChart(); 
                        loadDrillDownTable(`Periode: ${selectedTimeLabel}`, topLevelAgg[selectedTimeKey].items); 
                    } 
                }
            }
        });
    }

    function renderSubChart() {
        // PERBAIKAN: Menarik data menggunakan selectedTimeKey (YYYY-MM-DD), bukan label
        let items = topLevelAgg[selectedTimeKey].items;
        let subAgg = {};
        items.forEach(item => {
            let key = subDrillMode === "Line" ? getLineName(item.FunctionLocation) : getMachineName(item.FunctionLocation, item.ActivityText);
            if(!subAgg[key]) subAgg[key] = { mins: 0, items: [] };
            subAgg[key].mins += item.TotalDownTimeInMinutes;
            subAgg[key].items.push(item);
        });

        let labels = Object.keys(subAgg).sort((a,b) => subAgg[b].mins - subAgg[a].mins); 
        let dataMins = labels.map(k => subAgg[k].mins);

        const ctx = document.getElementById('barChart').getContext('2d');
        if (barChartInst) barChartInst.destroy();

        barChartInst = new Chart(ctx, {
            type: 'bar',
            data: { labels: labels, datasets: [{ label: `Total Downtime (Menit) - ${selectedTimeLabel}`, data: dataMins, backgroundColor: 'rgba(255, 159, 64, 0.85)', borderColor: 'rgba(255, 159, 64, 1)', borderWidth: 1, borderRadius: 4 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { datalabels: { anchor: 'end', align: 'top', color: getChartLabelColor, font: { weight: 'bold', size: 11 }, formatter: val => `${val} m` } }, scales: { y: { beginAtZero: true, suggestedMax: Math.max(...dataMins) * 1.2 } }, onClick: (e, elements) => { if (elements.length > 0) { const idx = elements[0].index; const key = labels[idx]; loadDrillDownTable(`${selectedTimeLabel} ➔ ${key}`, subAgg[key].items); } } }
        });
    }

    function updatePieChart(filteredData) {
        let reguAgg = { "Regu A": 0, "Regu B": 0, "Regu C": 0, "Lainnya": 0 };
        filteredData.forEach(item => {
            let shift = item.WageGroup_GroupShift || "Lainnya";
            if (shift.includes("A")) reguAgg["Regu A"] += item.TotalDownTimeInMinutes;
            else if (shift.includes("B")) reguAgg["Regu B"] += item.TotalDownTimeInMinutes;
            else if (shift.includes("C")) reguAgg["Regu C"] += item.TotalDownTimeInMinutes;
            else reguAgg["Lainnya"] += item.TotalDownTimeInMinutes;
        });

        const ctx = document.getElementById('pieChart').getContext('2d');
        if (pieChartInst) pieChartInst.destroy();
        pieChartInst = new Chart(ctx, { type: 'pie', data: { labels: Object.keys(reguAgg), datasets: [{ data: Object.values(reguAgg), backgroundColor: ['rgba(255, 99, 132, 0.8)', 'rgba(54, 162, 235, 0.8)', 'rgba(255, 206, 86, 0.8)', 'rgba(201, 203, 207, 0.8)'], borderWidth: 1 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { datalabels: { color: getChartLabelColor, font: { weight: 'bold', size: 11 }, formatter: (val) => val > 0 ? `${val}m` : null } } } });
    }

    function loadDrillDownTable(title, items) {
        document.getElementById('lblDetail').innerText = title;
        currentDrillDownData = items;
        renderTableRows();
    }

    function sortTable(colIdx) {
        if (currentTableMode === "Agg" || !currentDrillDownData || currentDrillDownData.length === 0) return; 
        if (sortState.col === colIdx) { sortState.asc = !sortState.asc; } else { sortState.col = colIdx; sortState.asc = true; }
        currentDrillDownData.sort((a, b) => {
            let valA, valB;
            if (colIdx === 0) { valA = new Date(a.NotificationDate); valB = new Date(b.NotificationDate); }
            else if (colIdx === 1) { valA = getLineName(a.FunctionLocation); valB = getLineName(b.FunctionLocation); }
            else if (colIdx === 2) { valA = getMachineName(a.FunctionLocation, a.ActivityText); valB = getMachineName(b.FunctionLocation, b.ActivityText); }
            else if (colIdx === 4) { valA = a.TotalDownTimeInMinutes; valB = b.TotalDownTimeInMinutes; }
            if (valA < valB) return sortState.asc ? -1 : 1;
            if (valA > valB) return sortState.asc ? 1 : -1;
            return 0;
        });
        renderTableRows();
    }

    function renderTableRows() {
        const thead = document.getElementById('table-header');
        const tbody = document.getElementById('table-body');

        if(currentDrillDownData.length === 0) { 
            tbody.innerHTML = `<tr><td colspan="6" class="text-center py-3">Tidak ada data.</td></tr>`; 
            return; 
        }

        if (currentTableMode === "Raw") {
            thead.innerHTML = `
                <tr>
                    <th style="cursor:pointer" onclick="sortTable(0)">Tanggal ⇅</th>
                    <th style="cursor:pointer" onclick="sortTable(1)">Line ⇅</th>
                    <th style="cursor:pointer" onclick="sortTable(2)">Mesin ⇅</th>
                    <th>Aktivitas Perbaikan (Activity Text)</th>
                    <th style="cursor:pointer" onclick="sortTable(4)">Menit ⇅</th>
                    <th>Regu</th>
                </tr>`;

            let html = "";
            currentDrillDownData.forEach(item => {
                const fDate = new Date(item.NotificationDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
                let txtAktivitas = item.ActivityText ? item.ActivityText : (item.NotificationDesc || '-');
                let namaLine = getLineName(item.FunctionLocation);
                let namaMesin = getMachineName(item.FunctionLocation, item.ActivityText);
                html += `<tr>
                    <td>${fDate}</td>
                    <td class="fw-bold text-success">${namaLine}</td>
                    <td class="fw-bold text-primary">${namaMesin}</td>
                    <td class="text-truncate" style="max-width: 230px;" title="${txtAktivitas}">${txtAktivitas}</td>
                    <td class="text-danger fw-bold">${item.TotalDownTimeInMinutes}</td>
                    <td><span class="badge bg-secondary">${item.WageGroup_GroupShift || '-'}</span></td>
                </tr>`;
            });
            tbody.innerHTML = html;

        } else {
            thead.innerHTML = `
                <tr>
                    <th>Line</th>
                    <th>Mesin</th>
                    <th>Aktivitas Berulang (Grouped Activity Text)</th>
                    <th class="text-center">Frekuensi (Kali)</th>
                    <th class="text-end">Total Durasi (Menit)</th>
                </tr>`;

            let aggMap = {};
            currentDrillDownData.forEach(item => {
                let line = getLineName(item.FunctionLocation);
                let machine = getMachineName(item.FunctionLocation, item.ActivityText);
                let txt = item.ActivityText ? item.ActivityText.trim() : (item.NotificationDesc || '-');
                let groupKey = `${line}||${machine}||${txt}`;

                if (!aggMap[groupKey]) {
                    aggMap[groupKey] = { line: line, machine: machine, text: txt, count: 0, duration: 0 };
                }
                aggMap[groupKey].count += 1;
                aggMap[groupKey].duration += item.TotalDownTimeInMinutes;
            });

            let sortedAgg = Object.values(aggMap).sort((a, b) => b.count - a.count);

            let html = "";
            sortedAgg.forEach(row => {
                html += `<tr>
                    <td class="fw-bold text-success">${row.line}</td>
                    <td class="fw-bold text-primary">${row.machine}</td>
                    <td class="text-truncate" style="max-width: 300px;" title="${row.text}">${row.text}</td>
                    <td class="text-center text-warning fw-bold fs-6">${row.count} x</td>
                    <td class="text-end text-danger fw-bold">${row.duration} min</td>
                </tr>`;
            });
            tbody.innerHTML = html;
        }
    }
</script>