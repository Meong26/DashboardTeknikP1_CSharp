@{
    ViewData["Title"] = "Manajemen Sparepart";
}

<div class="row mb-2 align-items-center" style="height: 8vh;">
    <div class="col">
        <h4 class="fw-bold text-primary mb-0"><i class="bi bi-box-seam me-2"></i> Sistem Manajemen Sparepart & EWS</h4>
        <small class="text-muted">Pantau ketersediaan material SAP, lokasi penyimpanan, dan peringatan dini stok kritis.</small>
    </div>
</div>

<div class="card shadow-sm border-0 mb-3 border-top border-4 border-danger d-flex flex-column" style="height: 38vh;">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-2 border-bottom">
        <span class="fw-bold text-danger" style="font-size: 0.9rem;">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> Early Warning System (Stok Habis & Kritis)
        </span>
        <span class="badge bg-danger rounded-pill px-3 py-1 fw-bold" id="ewsCount">0 Item</span>
    </div>
    <div class="card-body p-0 flex-grow-1" style="overflow-y: auto;">
        <table class="table table-hover table-sm mb-0 align-middle font-monospace" style="font-size: 0.85rem;" id="ewsTable">
            <thead class="table-dark sticky-top text-uppercase" style="z-index: 2;">
                <tr id="ewsTheadRow">
                    </tr>
            </thead>
            <tbody id="ewsTableBody" class="font-sans-serif">
                <tr><td colspan="6" class="text-center py-4"><div class="spinner-border text-danger spinner-border-sm me-2"></div> Memuat data EWS...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-transparent border-top py-2 px-3 text-muted d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
        <span style="font-size: 0.8rem;">
            Menampilkan <strong id="lblEwsStart" class="text-dark">0</strong> - <strong id="lblEwsEnd" class="text-dark">0</strong> 
            dari <strong id="lblEwsTotal" class="text-danger">0</strong> item kritis SAP.
        </span>
        <nav aria-label="Navigasi Halaman EWS">
            <ul class="pagination pagination-sm mb-0 shadow-sm" id="ewsPagination">
                </ul>
        </nav>
    </div>
</div>

<div class="card shadow-sm border-0 d-flex flex-column" style="height: 44vh;">
    <div class="card-header bg-transparent py-2 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 border-bottom">
        
        <div class="input-group input-group-sm shadow-sm" style="max-width: 350px;">
            <span class="input-group-text border-end-0 text-primary"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control border-start-0" id="smartSearch" placeholder="Ketik nomor part atau nama barang..." onkeyup="handleSearch()">
        </div>
        
        <div class="d-flex align-items-center gap-2">
            <select id="statusFilter" class="form-select form-select-sm border-secondary w-auto shadow-sm" onchange="handleStatusFilter()">
                <option value="ALL">Semua Status Suku Cadang</option>
                <option value="PRIORITY_ONLY">Khusus Sparepart Prioritas</option>
                <option value="EMPTY">Stok Kosong (0)</option>
                <option value="CRITICAL">Stok Kritis (≤ Safety Stock)</option>
                <option value="SAFE">Stok Aman</option>
            </select>
            <button class="btn btn-sm btn-outline-primary fw-bold shadow-sm" onclick="resetDashboard()">
                <i class="bi bi-arrow-clockwise me-1"></i> Reset
            </button>
        </div>
    </div>
     
    <div class="card-body p-0 flex-grow-1" style="overflow-y: auto;">
        <table class="table table-hover table-striped table-sm mb-0 align-middle font-monospace" style="font-size: 0.85rem;" id="sparepartTable">
            <thead class="table-dark sticky-top text-uppercase" style="z-index: 2;">
                <tr>
                    <th style="cursor:pointer; width: 15%;" onclick="sortTable(0)">No. Material ⇅</th>
                    <th style="cursor:pointer; width: 45%;" onclick="sortTable(1)">Deskripsi Sparepart ⇅</th>
                    <th style="cursor:pointer; width: 12%;" onclick="sortTable(2)">Stor. Loct ⇅</th>
                    <th style="cursor:pointer; width: 8%;" class="text-center" onclick="sortTable(3)">Safety ⇅</th>
                    <th style="cursor:pointer; width: 8%;" class="text-center" onclick="sortTable(4)">Aktual ⇅</th>
                    <th style="width: 12%;" class="text-center">Status</th>
                </tr>
            </thead>
            <tbody id="sparepartTableBody" class="font-sans-serif">
                <tr><td colspan="6" class="text-center py-5"><div class="spinner-border text-primary me-2"></div> Mengambil data dari SAP...</td></tr>
            </tbody>
        </table>
    </div>
    
    <div class="card-footer bg-transparent border-top py-2 px-3 text-muted d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
        <span style="font-size: 0.8rem;">
            Menampilkan <strong id="lblShowingStart" class="text-dark">0</strong> - <strong id="lblShowingEnd" class="text-dark">0</strong> 
            dari <strong id="lblTotalCount" class="text-primary">0</strong> baris material SAP.
        </span>
        <nav aria-label="Navigasi Halaman Data">
            <ul class="pagination pagination-sm mb-0 shadow-sm" id="paginationControls">
                </ul>
        </nav>
    </div>
</div>

<script>
    window.AppConfig = {
        canManagePRAndPriority: @((!User.IsInRole("Teknisi") && !User.IsInRole("WHS.SP")).ToString().ToLower())
    };
</script>
<script src="~/js/sparepart.js"></script>
