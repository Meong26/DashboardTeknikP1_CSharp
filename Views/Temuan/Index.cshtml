@{
    ViewData["Title"] = "Log Temuan Mesin";
}

<div class="row mb-3 align-items-center" style="height: 8vh;">
    <div class="col">
        <h4 class="fw-bold text-primary mb-0"><i class="bi bi-tools me-2"></i> Log Kerusakan & Abnormalitas</h4>
        <small class="text-muted">Catat temuan masalah mesin dengan cepat dan pantau status perbaikannya.</small>
    </div>
</div>

@if (!User.IsInRole("Supervisor"))
{
    @Html.AntiForgeryToken()
    <div class="card shadow-sm border-0 border-top border-4 border-primary mb-4">
        <div class="card-header bg-transparent py-2 d-flex justify-content-between align-items-center">
            <span class="fw-bold text-primary" style="font-size: 0.9rem;">
                <i class="bi bi-pencil-square me-1"></i> Form Input Cepat (Bisa input lebih dari 1 mesin)
            </span>
            <div class="spinner-border spinner-border-sm text-primary d-none" id="loadingForm"></div>
        </div>
        <div class="card-body p-0 table-responsive" style="max-height: 30vh; overflow-y: auto;">
            <table class="table table-bordered table-sm align-middle mb-0" style="font-size: 0.85rem;" id="tblInputTemuan">
                <thead class="table-dark sticky-top">
                    <tr class="text-center">
                        <th style="width: 15%;">Line</th>
                        <th style="width: 25%;">Kode / Nama Mesin</th>
                        <th style="width: 45%;">Deskripsi Masalah / Kendala</th>
                        <th style="width: 25%;">Tindakan Awal (Opsional)</th>
                        <th style="width: 5%;">Aksi</th>
                    </tr>
                </thead>
                <tbody id="inputBody">
                    </tbody>
            </table>
        </div>
        <div class="card-footer bg-transparent py-2 d-flex justify-content-between align-items-center">
            <button class="btn btn-sm btn-outline-secondary fw-bold" onclick="addNewRow()">+ Tambah Baris Masalah</button>
            <button class="btn btn-sm btn-primary fw-bold px-4 shadow-sm" onclick="saveDataTemuan()">
                <i class="bi bi-send-fill me-1"></i> Kirim Laporan
            </button>
        </div>
    </div>
}

<datalist id="listMasterMesin"></datalist>

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white py-2 d-flex justify-content-between align-items-center">
        <span class="fw-bold" style="font-size: 0.9rem;">
            <i class="bi bi-clock-history me-1"></i> Riwayat Laporan Temuan
        </span>
    </div>
    <div class="card-body p-0 table-responsive" style="max-height: 45vh; overflow-y: auto;">
        <table class="table table-hover table-striped mb-0" style="font-size: 0.85rem;">
            <thead class="table-dark sticky-top">
                <tr>
                    <th style="width: 15%; cursor: pointer;" onclick="sortTable('TanggalFormated')" id="th-TanggalFormated">Waktu Laporan <i class="bi bi-arrow-down-up ms-1 text-muted" style="font-size: 0.75rem;"></i></th>
                    <th style="width: 8%; cursor: pointer;" onclick="sortTable('Pelapor')" id="th-Pelapor">Pelapor <i class="bi bi-arrow-down-up ms-1 text-muted" style="font-size: 0.75rem;"></i></th>
                    <th style="width: 10%; cursor: pointer;" onclick="sortTable('Line')" id="th-Line">Line <i class="bi bi-arrow-down-up ms-1 text-muted" style="font-size: 0.75rem;"></i></th>
                    <th style="width: 20%; cursor: pointer;" onclick="sortTable('KodeMesin')" id="th-KodeMesin">Mesin Bermasalah <i class="bi bi-arrow-down-up ms-1 text-muted" style="font-size: 0.75rem;"></i></th>
                    <th style="width: 25%; cursor: pointer;" onclick="sortTable('DeskripsiAbnormal')" id="th-DeskripsiAbnormal">Deskripsi Kendala <i class="bi bi-arrow-down-up ms-1 text-muted" style="font-size: 0.75rem;"></i></th>
                    <th style="cursor: pointer;" onclick="sortTable('Status')" id="th-Status">Tindakan / Status <i class="bi bi-arrow-down-up ms-1 text-muted" style="font-size: 0.75rem;"></i></th>
                </tr>
            </thead>
            <tbody id="historyBody">
                <tr><td colspan="6" class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-secondary me-2"></div> Memuat riwayat...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL DETAIL CLOSED -->
<div class="modal fade" id="modalClosedDetail" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white py-2">
                <h6 class="modal-title fw-bold"><i class="bi bi-check2-circle me-1"></i> Detail Penutupan Laporan</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="font-size: 0.9rem;">
                <div class="mb-3">
                    <label class="text-muted small fw-bold">Tanggal Ditutup</label>
                    <div id="lblTanggalClosed" class="fw-bold"></div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small fw-bold">Ditutup Oleh (Teknisi/Section)</label>
                    <div id="lblClosedBy" class="fw-bold text-primary"></div>
                </div>
                <div class="mb-2">
                    <label class="text-muted small fw-bold">Tindakan Perbaikan yang Dilakukan</label>
                    <div id="lblTindakanKorektif" class="p-2 bg-secondary-subtle border rounded text-break text-body-emphasis"></div>
                </div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Tutup</button>
            </div>
        </div>
    </div>
</div>

<script>
    const canCloseLaporan = @((!User.IsInRole("Supervisor") && !User.IsInRole("Teknisi")).ToString().ToLower());
    let masterMesin = [];
    let historyTemuan = [];

    document.addEventListener("DOMContentLoaded", async () => {
        await fetchApiData();
    });

    async function fetchApiData() {
        document.getElementById('loadingForm').classList.remove('d-none');
        try {
            const response = await fetch('/Temuan/GetApiData');
            const data = await response.json();
            
            masterMesin = data.mesin;
            historyTemuan = data.history;
            
            populateDatalist();
            renderHistoryTable();
            
            // Pastikan minimal ada 1 baris kosong di form jika form ada
            if (document.getElementById('inputBody') && document.getElementById('inputBody').children.length === 0) {
                addNewRow();
            }
        } catch (error) {
            console.error("Gagal menarik data API Temuan", error);
        } finally {
            document.getElementById('loadingForm').classList.add('d-none');
        }
    }

    function populateDatalist() {
        const dataList = document.getElementById('listMasterMesin');
        dataList.innerHTML = "";
        masterMesin.forEach(m => {
            // Kombinasi Kode dan Nama agar teknisi bisa mengetik salah satunya
            dataList.innerHTML += `<option value="${m.KodeMesin}">[${m.KodeMesin}] - ${m.NamaMesin}</option>`;
        });
    }

    // =========================================================
    // LOGIKA FORM INPUT CELERITY (EXCEL-STYLE)
    // =========================================================
    function addNewRow() {
        const tbody = document.getElementById('inputBody');
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>
                <select class="form-select form-select-sm border-0 bg-transparent fw-bold text-success inp-line" onkeydown="handleEnter(event, this, '.inp-mesin')">
                    <option value="" disabled selected>Pilih...</option>
                    <option value="Line 1">Line 1</option>
                    <option value="Line 2">Line 2</option>
                    <option value="Line 3">Line 3</option>
                    <option value="Line 4">Line 4</option>
                    <option value="Line 5">Line 5</option>
                    <option value="Line 6">Line 6</option>
                    <option value="Line 7">Line 7</option>
                    <option value="Line 8">Line 8</option>
                    <option value="Line 9">Line 9</option>
                    <option value="SILO">SILO</option>
                    <option value="Emulsik">Emulsik</option>
                    <option value="Umum">Umum</option>
                </select>
            </td>
            <td>
                <input list="listMasterMesin" class="form-control form-control-sm border-0 bg-transparent fw-bold text-primary inp-mesin" placeholder="Ketik/Pilih Mesin..." onchange="validateMesin(this)" onkeydown="handleEnter(event, this, '.inp-desc')">
            </td>
            <td>
                <input type="text" class="form-control form-control-sm border-0 bg-transparent inp-desc" placeholder="Jelaskan kendala mesin..." onkeydown="handleEnter(event, this, '.inp-tindakan')">
            </td>
            <td>
                <input type="text" class="form-control form-control-sm border-0 bg-transparent text-muted inp-tindakan" placeholder="Biarkan kosong jika belum ada..." onkeydown="handleEnter(event, this, 'NEW_ROW')">
            </td>
            <td class="text-center align-middle">
                <button class="btn btn-sm text-danger border-0 p-0" onclick="removeRow(this)" tabindex="-1"><i class="bi bi-trash fs-5"></i></button>
            </td>
        `;
        tbody.appendChild(tr);
        tr.querySelector('.inp-line').focus(); // Auto-focus pindah ke Line
    }

    function removeRow(btn) { 
        const tbody = document.getElementById('inputBody'); 
        if (tbody.children.length > 1) { 
            btn.closest('tr').remove(); 
        } else { 
            // Jika sisa 1 baris, bersihkan saja isinya
            const row = btn.closest('tr'); 
            row.querySelector('.inp-mesin').value = ""; 
            row.querySelector('.inp-desc').value = ""; 
            row.querySelector('.inp-tindakan').value = ""; 
        } 
    }

    function validateMesin(inputElement) {
        const val = inputElement.value.trim();
        if (val === "") return;
        
        // Cek apakah inputan ada di daftar KodeMesin
        const isExist = masterMesin.some(m => m.KodeMesin === val);
        if (!isExist) {
            alert("Kode Mesin tidak valid! Silakan pilih dari rekomendasi yang muncul.");
            inputElement.value = "";
            inputElement.focus();
        }
    }

    function handleEnter(e, currentElement, nextSelector) {
        if (e.ctrlKey && e.key === 'Enter') {
            e.preventDefault();
            saveDataTemuan();
            return;
        }

        if (e.key === 'Tab' || e.key === 'Enter') {
            e.preventDefault();
            const currentRow = currentElement.closest('tr');
            
            if (nextSelector === 'NEW_ROW') {
                const tbody = document.getElementById('inputBody');
                if (currentRow === tbody.lastElementChild) {
                    addNewRow();
                } else {
                    currentRow.nextElementSibling.querySelector('.inp-line').focus();
                }
            } else {
                currentRow.querySelector(nextSelector).focus();
            }
        }
    }

    async function saveDataTemuan() {
        const rows = document.querySelectorAll('#inputBody tr');
        let payload = []; 
        let hasError = false;

        rows.forEach((row, index) => {
            const lineData = row.querySelector('.inp-line').value.trim();
            const mesin = row.querySelector('.inp-mesin').value.trim();
            const desc = row.querySelector('.inp-desc').value.trim();
            const tindakan = row.querySelector('.inp-tindakan').value.trim();

            if (mesin === "" && desc === "" && lineData === "") return; 

            if (lineData === "") { alert(`Baris ke-${index + 1}: Line belum diisi.`); hasError = true; return; }
            if (mesin === "") { alert(`Baris ke-${index + 1}: Kode Mesin belum diisi.`); hasError = true; return; }
            if (desc === "") { alert(`Baris ke-${index + 1}: Deskripsi masalah wajib diisi.`); hasError = true; return; }

            payload.push({
                Line: lineData, // TAMBAHAN BARU
                KodeMesin: mesin,
                DeskripsiAbnormal: desc,
                TindakanKorektif: tindakan
            });
        });

        if (hasError) return;
        if (payload.length === 0) { alert("Tidak ada data yang diisi."); return; }

        const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenElement ? tokenElement.value : '';

        try {
            const response = await fetch('/Temuan/SaveDataFast', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            });

            if (response.ok) {
                // Bersihkan form
                document.getElementById('inputBody').innerHTML = "";
                addNewRow();
                // Tarik ulang data agar tabel bawah terupdate seketika
                await fetchApiData(); 
            } else {
                alert("Gagal menyimpan laporan temuan.");
            }
        } catch (error) {
            alert("Terjadi kesalahan jaringan.");
        }
    }

    // =========================================================
    // RENDER TABEL HISTORY BAWAH
    // =========================================================
    function renderHistoryTable() {
        const tbody = document.getElementById('historyBody');
        
        if (historyTemuan.length === 0) {
            tbody.innerHTML = `<tr><td colspan="6" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-3 d-block mb-2"></i> Belum ada laporan temuan.</td></tr>`;
            return;
        }

        let htmlGrid = "";
        historyTemuan.forEach(item => {
            
            // Logika pewarnaan status dan tombol aksi
            let statusBadge = "";
            if (item.Status === "OPEN") {
                let closeBtn = canCloseLaporan ? `
                        <a href="/Temuan/Close/${item.TemuanID}" class="btn btn-sm btn-outline-danger py-0 px-2 fw-bold" style="font-size: 0.75rem; transition: transform 0.2s;" onmouseover="this.style.transform='translateX(3px)'" onmouseout="this.style.transform='translateX(0)'">
                            Tutup Laporan &rarr;
                        </a>` : '';
                statusBadge = `
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-danger shadow-sm">OPEN</span>
                        ${closeBtn}
                    </div>`;
            } else if (item.Status === "CLOSED") {
                statusBadge = `<span class="badge bg-success shadow-sm"><i class="bi bi-check2-all me-1"></i>CLOSED</span>`;
            } else {
                statusBadge = `<span class="badge bg-warning text-dark">${item.Status}</span>`;
            }

            let rowAttr = "";
            let trClass = "";
            if (item.Status === "CLOSED") {
                let safeTindakan = item.TindakanKorektif ? item.TindakanKorektif.replace(/'/g, "&#39;").replace(/"/g, "&quot;") : "-";
                rowAttr = `style="cursor: pointer;" onclick="showCloseModal('${item.TanggalClosedFormated}', '${item.ClosedByName}', '${safeTindakan}')"`;
                trClass = `class="table-success-hover" title="Klik untuk melihat detail perbaikan"`;
            }

            htmlGrid += `
                <tr ${rowAttr} ${trClass}>
                    <td>${item.TanggalFormated}</td>
                    <td><span class="badge bg-secondary font-monospace">${item.Pelapor}</span></td>
                    
                    <td class="fw-bold text-success">${item.Line}</td>
                    
                    <td>
                        <div class="fw-bold text-body-emphasis text-nowrap">${item.KodeMesin}</div>
                        <small class="text-muted d-block text-truncate" style="max-width: 180px;">${item.NamaMesin}</small>
                    </td>
                    <td><div class="text-break pe-2" style="max-height: 3.6em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">${item.DeskripsiAbnormal}</div></td>
                    <td class="align-middle">
                        ${statusBadge}
                        ${item.Status === 'CLOSED' 
                            ? `<div class="mt-1 small text-muted"><i class="bi bi-clock me-1"></i>Closed at ${item.TanggalClosedFormated}</div>` 
                            : `<div class="mt-1 text-muted small text-truncate" style="max-width: 200px;" title="${item.TindakanKorektif}">${item.TindakanKorektif}</div>`
                        }
                    </td>
                </tr>
            `;
        });
        
        tbody.innerHTML = htmlGrid;
    }

    function showCloseModal(tanggal, closedBy, tindakan) {
        document.getElementById('lblTanggalClosed').innerText = tanggal;
        document.getElementById('lblClosedBy').innerText = closedBy;
        document.getElementById('lblTindakanKorektif').innerHTML = tindakan; // innerHTML karena ada encode HTML
        var myModal = new bootstrap.Modal(document.getElementById('modalClosedDetail'));
        myModal.show();
    }

    let sortColumn = "";
    let sortAscending = true;

    function sortTable(column) {
        if (sortColumn === column) {
            sortAscending = !sortAscending;
        } else {
            sortColumn = column;
            sortAscending = true;
        }

        historyTemuan.sort((a, b) => {
            let valA = a[column];
            let valB = b[column];

            if (valA === null || valA === undefined) valA = "";
            if (valB === null || valB === undefined) valB = "";

            // Handle date parsing for TanggalFormated
            if (column === 'TanggalFormated') {
                valA = new Date(valA).getTime();
                valB = new Date(valB).getTime();
                // if invalid date, fallback to 0
                if (isNaN(valA)) valA = 0;
                if (isNaN(valB)) valB = 0;
            } else {
                if (typeof valA === "string") valA = valA.toLowerCase();
                if (typeof valB === "string") valB = valB.toLowerCase();
            }

            if (valA < valB) return sortAscending ? -1 : 1;
            if (valA > valB) return sortAscending ? 1 : -1;
            return 0;
        });

        renderHistoryTable();
        updateSortIcons(column);
    }

    function updateSortIcons(column) {
        // Reset all icons to default
        const thElements = document.querySelectorAll('thead th');
        thElements.forEach(th => {
            const icon = th.querySelector('i');
            if (icon) {
                icon.className = 'bi bi-arrow-down-up ms-1 text-muted';
            }
        });

        // Set the active sort icon
        const activeTh = document.getElementById('th-' + column);
        if (activeTh) {
            const icon = activeTh.querySelector('i');
            if (icon) {
                if (sortAscending) {
                    icon.className = 'bi bi-arrow-up ms-1 text-primary';
                } else {
                    icon.className = 'bi bi-arrow-down ms-1 text-primary';
                }
            }
        }
    }
</script>

<style>
    /* Styling agar datalist dan input menyatu mulus */
    .inp-mesin::-webkit-calendar-picker-indicator {
        cursor: pointer;
        opacity: 0.6;
        transition: opacity 0.2s;
    }
    .inp-mesin::-webkit-calendar-picker-indicator:hover {
        opacity: 1;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(0,0,0,0.02);
    }
    .table-success-hover:hover {
        background-color: rgba(25, 135, 84, 0.05) !important;
    }
</style>