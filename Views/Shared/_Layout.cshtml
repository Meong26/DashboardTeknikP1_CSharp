<!DOCTYPE html>
<html lang="en" id="html-root" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dashboard Teknik P1</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        /* --- Kustomisasi Layout Sidebar & Wrapper --- */
        body { 
            overflow-x: hidden; 
            transition: background-color 0.2s ease, color 0.2s ease;
        }
        
        #wrapper {
            display: flex;
            width: 100vw;
            height: 100vh;
            overflow: hidden;
        }

        /* Sidebar Styling - OPTIMASI GPU */
        #sidebar-wrapper {
            min-height: 100vh;
            width: 250px;
            transition: width 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            will-change: width; 
            display: flex;
            flex-direction: column;
            z-index: 1000;
            overflow: visible; /* Diubah jadi visible agar dropup profil tidak terpotong */
        }

        #sidebar-wrapper.collapsed {
            width: 75px;
        }

        /* --- HEADER SIDEBAR (AREA LOGO) --- */
        .sidebar-heading {
            min-height: 65px;
            overflow: hidden;
            cursor: pointer;
            transition: background-color 0.2s ease;
            white-space: nowrap; 
        }
        .sidebar-heading:hover {
            background-color: rgba(255,255,255,0.05);
        }

        .collapsed-view { display: none; }
        .expanded-view { display: flex; }

        #sidebar-wrapper.collapsed .expanded-view { display: none !important; }
        #sidebar-wrapper.collapsed .collapsed-view { display: flex; }

        /* Item Menu Navigasi */
        .sidebar-menu .list-group-item {
            border: none;
            padding: 1rem 1.5rem;
            white-space: nowrap; 
            overflow: hidden;
            display: flex;
            align-items: center;
            background: transparent;
            color: #d1d5db; 
            transition: background 0.2s, color 0.2s;
            cursor: pointer;
        }

        .sidebar-menu .list-group-item:hover, .sidebar-menu .list-group-item.active {
            background-color: rgba(255, 255, 255, 0.1);
            color: #ffffff;
            border-left: 4px solid #ffc107;
        }

        .sidebar-menu .list-group-item i {
            font-size: 1.3rem;
            margin-right: 15px;
            min-width: 25px;
            text-align: center;
        }

        /* Menu Navigasi Mode Sembunyi */
        #sidebar-wrapper.collapsed .list-group-item {
            padding: 1rem;
            justify-content: center;
            border-left: none; 
        }
        #sidebar-wrapper.collapsed .list-group-item.active {
            background-color: rgba(255, 255, 255, 0.1);
        }
        #sidebar-wrapper.collapsed .list-group-item i {
            margin-right: 0;
        }
        #sidebar-wrapper.collapsed .nav-text {
            display: none;
        }
        
        /* Sembunyikan panah dropup profil saat sidebar ciut */
        #sidebar-wrapper.collapsed .dropdown-toggle::after {
            display: none;
        }

        /* Area Konten Utama */
        #page-content-wrapper {
            flex-grow: 1;
            overflow-y: auto;
            overflow-x: hidden; 
            display: flex;
            flex-direction: column;
            will-change: width, flex-grow; 
        }
    </style>
</head>
<body class="bg-body-tertiary">

    <div id="wrapper">
        <div class="bg-dark" id="sidebar-wrapper">
            
            <div class="sidebar-heading border-bottom border-secondary d-flex align-items-center justify-content-center w-100" id="sidebarToggleArea" title="Klik untuk sembunyikan/buka menu">
                
                <div class="expanded-view flex-column align-items-center justify-content-center py-3 w-100">
                    <img src="~/images/logo_indofood.svg" alt="Logo" height="38" class="mb-2" style="object-fit: contain;">
                    <span class="fw-bold text-warning text-center" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                        Teknik P1 Super App
                    </span>
                </div>

                <div class="collapsed-view align-items-center justify-content-center w-100 py-3 text-white">
                    <i class="bi bi-list fs-2"></i>
                </div>

            </div>
            
            <div class="list-group list-group-flush sidebar-menu mt-3 flex-grow-1" style="overflow-y: auto; overflow-x: hidden;">
                <a href="/" class="list-group-item list-group-item-action text-decoration-none nav-link-item">
                    <i class="bi bi-bar-chart-fill"></i> <span class="nav-text">Analitik Performa</span>
                </a>
                <a href="/Temuan" class="list-group-item list-group-item-action text-decoration-none nav-link-item">
                    <i class="bi bi-tools"></i> <span class="nav-text">Log Kerusakan</span>
                </a>
                
                <a href="/Sparepart" class="list-group-item list-group-item-action text-decoration-none nav-link-item">
                    <i class="bi bi-box-seam"></i> <span class="nav-text">Manajemen Sparepart</span>
                </a>
                
                <a href="/Upload" class="list-group-item list-group-item-action text-decoration-none nav-link-item">
                    <i class="bi bi-cloud-arrow-up-fill"></i> <span class="nav-text">Sinkronisasi SAP</span>
                </a>
            </div>
            
            <div class="list-group list-group-flush sidebar-menu mt-auto border-top border-secondary pb-2 pt-2">
                
                <div class="list-group-item list-group-item-action" id="btnThemeToggle" title="Ganti Tema">
                    <i class="bi bi-moon-stars-fill" id="themeIcon"></i> 
                    <span class="nav-text">Mode Gelap</span>
                </div>

                <div class="dropup w-100">
                    <div class="list-group-item list-group-item-action dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" id="accountDropup" title="Profil Akun">
                        <i class="bi bi-person-circle text-warning"></i> 
                        <span class="nav-text">
                            @(User.Identity?.IsAuthenticated == true ? User.Identity.Name : "Pengguna")
                        </span>
                    </div>
                    <ul class="dropdown-menu dropdown-menu-dark shadow-lg mb-2 ms-2" style="min-width: 200px;">
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var role = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
                            <li><span class="dropdown-item-text text-warning fw-bold pb-0" style="font-size: 0.8rem;">Akses: @role</span></li>
                            <li><hr class="dropdown-divider border-secondary mt-2"></li>
                        }

                        <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-3"></i>Pengaturan</a></li>
                        <li><hr class="dropdown-divider border-secondary"></li>
                        
                        <li><a class="dropdown-item text-danger py-2" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-3"></i>Keluar</a></li>
                    </ul>
                </div>

            </div>
        </div>

        <div id="page-content-wrapper">
            <div class="container-fluid p-4 bg-body-tertiary flex-grow-1">
                @RenderBody()
            </div>
            
            <footer class="bg-white border-top py-3 text-center text-muted small mt-auto" id="main-footer">
                &copy; 2026 - Indofood CBP Noodle Division Cibitung
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', (event) => {
            const sidebarWrapper = document.getElementById('sidebar-wrapper');
            const sidebarToggleArea = document.getElementById('sidebarToggleArea'); 

            // --- 1. LOGIKA TOGGLE SUPER APP ---
            const isSidebarCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            if (isSidebarCollapsed) {
                sidebarWrapper.classList.add('collapsed');
            }

            function toggleSidebar() {
                sidebarWrapper.classList.toggle('collapsed');
                const isCollapsedNow = sidebarWrapper.classList.contains('collapsed');
                localStorage.setItem('sidebarCollapsed', isCollapsedNow);
                
                setTimeout(() => {
                    window.dispatchEvent(new Event('resize')); // Resize grafik Chart.js
                }, 300);
            }

            sidebarToggleArea.addEventListener('click', toggleSidebar);

            // --- 2. LOGIKA DARK MODE (KLIK BARIS MENU) ---
            const htmlElement = document.getElementById('html-root');
            const themeToggleBtn = document.getElementById('btnThemeToggle');
            const themeIcon = document.getElementById('themeIcon');
            const footer = document.getElementById('main-footer');

            const currentTheme = localStorage.getItem('theme') || 'light';
            htmlElement.setAttribute('data-bs-theme', currentTheme);
            updateColors(currentTheme);

            themeToggleBtn.addEventListener('click', function () {
                const activeTheme = htmlElement.getAttribute('data-bs-theme');
                const newTheme = activeTheme === 'dark' ? 'light' : 'dark';
                
                htmlElement.setAttribute('data-bs-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                updateColors(newTheme);
            });

            function updateColors(theme) {
                const textSpan = themeToggleBtn.querySelector('.nav-text');
                if(theme === 'dark'){
                    themeIcon.classList.replace('bi-moon-stars-fill', 'bi-sun-fill');
                    themeIcon.classList.add('text-warning');
                    textSpan.innerText = "Mode Terang";
                    footer.classList.replace('bg-white', 'bg-dark');
                    footer.classList.replace('border-top', 'border-secondary');
                } else {
                    themeIcon.classList.replace('bi-sun-fill', 'bi-moon-stars-fill');
                    themeIcon.classList.remove('text-warning');
                    textSpan.innerText = "Mode Gelap";
                    footer.classList.replace('bg-dark', 'bg-white');
                    footer.classList.replace('border-secondary', 'border-top');
                }
            }
            
            // --- 3. AUTO-ACTIVE MENU STATE ---
            const currentLocation = window.location.pathname;
            // Hanya targetkan menu utama (abaikan menu akun/tema)
            const menuItems = document.querySelectorAll('.nav-link-item'); 
            
            menuItems.forEach(item => {
                const itemHref = item.getAttribute('href');
                if (currentLocation === itemHref || (currentLocation.startsWith(itemHref) && itemHref !== '/')) {
                    item.classList.add('active');
                }
            });
        });
    </script>
</body>
</html>