@model DashboardTeknikP1.Models.LoginViewModel

@{
    Layout = null; // Menghilangkan menu samping (sidebar)
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Masuk - Dashboard Teknik P1</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            border: none;
            border-top: 5px solid #0d6efd;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card login-card p-4">
                    <div class="text-center mb-4">
                        <img src="/images/logo_indofood.svg" alt="Logo Indofood" height="50" class="mb-3">
                        <h5 class="fw-bold text-dark">Portal Teknik P1</h5>
                        <p class="text-muted small">Silakan masuk menggunakan NIK Karyawan</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger p-2 small text-center rounded">
                            @Html.ValidationSummary(false, "", new { @class = "mb-0 list-unstyled" })
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">Nomor Induk Karyawan (NIK)</label>
                            <input asp-for="UserID" class="form-control form-control-lg fs-6" placeholder="Contoh: 50100980" autocomplete="off" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">Kata Sandi</label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg fs-6" placeholder="Masukkan kata sandi" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow-sm">MASUK SISTEM</button>
                    </form>
                </div>
                <div class="text-center mt-3 text-muted" style="font-size: 0.75rem;">
                    &copy; 2026 PT Indofood CBP - Noodle Division
                </div>
            </div>
        </div>
    </div>
</body>
</html>