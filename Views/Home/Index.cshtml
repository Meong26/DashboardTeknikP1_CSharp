                                    <th style="padding: 6px; border: 1px solid #ddd; width: 35%;">Aktivitas Perbaikan</th>
                                    <th style="padding: 6px; border: 1px solid #ddd; width: 10%;">Menit</th>
                                    <th style="padding: 6px; border: 1px solid #ddd; width: 10%;">Regu</th>
