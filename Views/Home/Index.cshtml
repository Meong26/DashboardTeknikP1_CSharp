@{
    ViewData["Title"] = "Analitik Performa";
}

<div class="row mb-3 g-2" id="rowBadActors">
    </div>


<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Mode Dimensi Tren</label>
        <select id="dimMode" class="form-select form-select-sm border-primary" onchange="handleModeChange()">
            <option value="Year">Berdasarkan Tahun</option>
            <option value="Month" selected >Berdasarkan Bulan</option>
            <option value="Week">Berdasarkan Minggu</option>
        </select>
    </div>

    <div class="col-md-2 d-none" id="divFltBulan">
        <label class="form-label fw-bold small text-muted mb-1 text-primary">Pilih Bulan</label>
        <select id="fltBulan" class="form-select form-select-sm border-primary" onchange="updateDashboard()">
        </select>
    </div>

    <div class="col-md-2 d-none" id="divFltMinggu">
        <label class="form-label fw-bold small text-muted mb-1 text-primary">Pilih Minggu</label>
        <select id="fltMinggu" class="form-select form-select-sm border-primary" onchange="updateDashboard()">
        </select>
    </div>


    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Jenis Notifikasi</label>
        <select id="fltNotif" class="form-select form-select-sm" onchange="updateDashboard()">
            <option value="">Semua (NV & NT)</option>
            <option value="NV">NV - DT Lain Lain</option>
            <option value="NT" selected>NT - DT Mesin</option>
        </select>
    </div>
    
    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Regu / Shift</label>
        <select id="fltShift" class="form-select form-select-sm" onchange="updateDashboard()">
            <option value="">Semua Regu (A, B, C)</option>
            <option value="A">Regu A</option>
            <option value="B">Regu B</option>
            <option value="C">Regu C</option>
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Pilih Line</label>
        <select id="fltLine" class="form-select form-select-sm" onchange="updateDashboard()">
            <option value="">All Line</option>
            <option value="Line 1">Line 1</option>
            <option value="Line 2">Line 2</option>
            <option value="Line 3">Line 3</option>
            <option value="Line 4">Line 4</option>
            <option value="Line 5">Line 5</option>
            <option value="Line 6">Line 6</option>
            <option value="Line 7">Line 7</option>
            <option value="Line 8">Line 8</option>
        </select>
    </div>

    <div class="col-md-2 mb-1">
        <div class="form-check">
            <input class="form-check-input border-danger" type="checkbox" id="chkSteam" onchange="updateDashboard()">
            <label class="form-check-label fw-bold small text-danger" for="chkSteam" style="font-size: 0.8rem;">
                Include Steam Drop
            </label>
        </div>
    </div>
</div>

<div class="row mb-3 g-3 d-print-none animate__animated animate__fadeIn">
    <div class="col-md-3">
        <div class="card bg-body shadow-sm border-0" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'" onclick="openDTAchievementDetails()" title="Pencapaian Downtime vs Terencana (Minggu Ini)">
            <div class="card-body py-2 px-3 d-flex flex-column justify-content-center">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <div class="small fw-bold text-uppercase text-muted" style="font-size: 0.7rem;"><i class="bi bi-speedometer2 me-1"></i> PENCAPAIAN DT NT (MINGGU INI)</div>
                    <i class="bi bi-graph-down text-primary opacity-50" style="font-size: 1.5rem;"></i>
                </div>
                <div class="d-flex align-items-baseline mb-2">
                    <h4 class="mb-0 fw-bold me-2" id="lblDTAchievement">0.0 %</h4>
                    <span class="small fw-bold text-danger me-2" id="lblDTMins" style="font-size: 0.85rem;">(0 mnt)</span>
                    <span class="small fw-bold text-muted" style="font-size: 0.75rem;">(Target: &le; 1.5%)</span>
                </div>
                <div class="progress" style="height: 6px;">
                    <div id="pbDTAchievement" class="progress-bar bg-success" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white shadow-sm border-0" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'" onclick="openMTTRDetails()" title="Klik untuk melihat Analitik Mendalam MTTR">
            <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="small fw-bold text-uppercase opacity-75 mb-1" style="font-size: 0.7rem;"><i class="bi bi-tools me-1"></i> Mean Time To Repair (MTTR)</div>
                    <h4 class="mb-0 fw-bold" id="lblMTTR">0 Menit</h4>
                </div>
                <i class="bi bi-stopwatch text-white opacity-50" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white shadow-sm border-0" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'" onclick="openMTBFDetails()" title="Klik untuk melihat Analitik Mendalam MTBF">
            <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="small fw-bold text-uppercase opacity-75 mb-1" style="font-size: 0.7rem;"><i class="bi bi-shield-check me-1"></i> Mean Time Between Failures (MTBF)</div>
                    <h4 class="mb-0 fw-bold" id="lblMTBF">0 Menit</h4>
                </div>
                <i class="bi bi-activity text-white opacity-50" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-primary text-white shadow-sm border-0" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'" onclick="openAvailabilityDetails()" title="Klik untuk melihat Analitik Mendalam Availability">
            <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="small fw-bold text-uppercase opacity-75 mb-1" style="font-size: 0.7rem;"><i class="bi bi-percent me-1"></i> Machine Availability</div>
                    <h4 class="mb-0 fw-bold" id="lblAvailability">0 %</h4>
                </div>
                <i class="bi bi-bar-chart-line text-white opacity-50" style="font-size: 2rem;"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mb-3" style="height: 45vh;">
    <div class="col-12 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-transparent border-bottom-0 d-flex justify-content-between align-items-center py-2">
                <span class="fw-bold fs-6" id="mainChartTitle">📊 Analitik Downtime vs Jam Terencana</span>
                
                <div class="d-flex align-items-center">
                    <button id="btnReportBuilder" class="btn btn-sm btn-outline-danger fw-bold me-2 shadow-sm" onclick="openReportBuilder()">
                        <i class="bi bi-file-earmark-pdf me-1"></i> Buat Summary Laporan
                    </button>
                    <button id="btnZoomChart" class="btn btn-sm btn-outline-info fw-bold me-3 shadow-sm" onclick="toggleChartZoom()">
                        <i class="bi bi-arrows-angle-expand me-1"></i> Zoom & Scroll
                    </button>

                    <div class="form-check form-switch me-4 mb-0" id="paretoToggleContainer">
                        <input class="form-check-input border-warning" type="checkbox" role="switch" id="chkPareto" onchange="updateDashboard()">
                        <label class="form-check-label fw-bold small text-warning" for="chkPareto">⚠️ Mode Pareto</label>
                    </div>

                    <div id="drillControls" class="d-none animate__animated animate__fadeIn">
                        <div class="btn-group btn-group-sm me-3 shadow-sm" role="group">
                            <input type="radio" class="btn-check" name="drillGroup" id="dgLine" autocomplete="off" checked onchange="changeSubDrillGroup('Line')">
                            <label class="btn btn-outline-primary fw-bold" for="dgLine">Line</label>
                            
                            <input type="radio" class="btn-check" name="drillGroup" id="dgMachine" autocomplete="off" onchange="changeSubDrillGroup('Machine')">
                            <label class="btn btn-outline-primary fw-bold" for="dgMachine">Mesin</label>
                        </div>
                        <button class="btn btn-sm btn-secondary fw-bold shadow-sm" onclick="goBackToMainChart()">
                            <i class="bi bi-arrow-left me-1"></i> Kembali
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="card-body p-2 position-relative" style="overflow-x: auto; overflow-y: hidden;">
                <div id="chartCanvasWrapper" style="min-width: 100%; height: 100%; transition: min-width 0.3s ease;">
                    <canvas id="barChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row" style="height: 40vh;">
    <div class="col-md-7 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-transparent border-bottom border-warning d-flex justify-content-between align-items-center py-2">
                <span class="fw-bold small">🔍 Rincian Aktivitas: <span id="lblDetail" class="text-primary">Pilih Batang Grafik</span></span>
                
                <div class="btn-group btn-group-sm" role="group">
                    <input type="radio" class="btn-check" name="tableMode" id="tmRaw" autocomplete="off" checked onchange="changeTableMode('Raw')">
                    <label class="btn btn-outline-secondary font-monospace" for="tmRaw">Detail</label>
                    
                    <input type="radio" class="btn-check" name="tableMode" id="tmAgg" autocomplete="off" onchange="changeTableMode('Agg')">
                    <label class="btn btn-outline-secondary font-monospace" for="tmAgg">Agregasi (Frekuensi)</label>
                </div>
            </div>
            <div class="card-body p-0" style="overflow-y: auto;">
                <table class="table table-sm table-hover table-striped mb-0" style="font-size: 0.85rem;" id="mainTable">
                    <thead class="table-dark sticky-top" id="table-header"></thead>
                    <tbody id="table-body">
                        <tr><td colspan="6" class="text-center py-4 text-muted">Klik salah satu titik waktu pada grafik di atas untuk melihat detail.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-5 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-transparent border-bottom border-primary py-2 d-flex justify-content-between align-items-center">
                <span class="fw-bold small">🍩 Proporsi Downtime per Regu (Menit)</span>
                <button id="btnResetRegu" class="btn btn-sm btn-outline-secondary d-none" style="font-size: 0.7rem; padding: 2px 5px;" onclick="resetReguFilter()">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </button>
            </div>
            <div class="card-body p-2" style="position: relative; flex-grow: 1; min-height: 0;">
                <canvas id="pieChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/chartjs/chart.min.js"></script>
<script src="~/lib/chartjs/chartjs-plugin-datalabels.min.js"></script>
<script src="~/lib/html2canvas.min.js"></script>
<script src="~/lib/jspdf.umd.min.js"></script>

<style>
    .animate__fadeIn { animation: fadeIn 0.3s; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .bad-actor-card { transition: transform 0.2s; cursor: pointer; }
    .bad-actor-card:hover { transform: translateY(-2px); }
    .drill-link { 
        cursor: pointer; 
        text-decoration: underline; 
        text-decoration-style: dotted; 
        transition: opacity 0.2s;
    }
    .drill-link:hover { opacity: 0.7; }
</style>

<!-- REPORT BUILDER MODAL -->
@await Html.PartialAsync("_ReportBuilderModal")

<div class="modal fade" id="modalDTAchievement" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-top border-4 border-success" id="modalDTAchievementBorder">
            <div class="modal-header bg-body-secondary py-2">
                <h5 class="modal-title fw-bold text-success"><i class="bi bi-speedometer2 me-2"></i> Rincian Pencapaian DT NT (Minggu Ini)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-body-tertiary">
                <div class="row g-3">
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-4 text-center">
                                <h3 class="fw-bold mb-3" id="modalDTPercentage">0.0 %</h3>
                                <div class="progress mb-3" style="height: 25px;">
                                    <div id="modalDTProgressBar" class="progress-bar bg-success progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%; font-size: 1rem; font-weight: bold;"></div>
                                </div>
                                <div class="d-flex justify-content-center gap-4">
                                    <div class="bg-body-secondary rounded p-2 px-3 border shadow-sm">
                                        <span class="small text-muted fw-bold d-block text-uppercase">Total DT NT</span>
                                        <span class="fs-4 fw-bold text-danger" id="modalDTMins">0 Menit</span>
                                    </div>
                                    <div class="bg-body-secondary rounded p-2 px-3 border shadow-sm">
                                        <span class="small text-muted fw-bold d-block text-uppercase">Total Jam Terencana</span>
                                        <span class="fs-4 fw-bold text-primary" id="modalPlannedMins">0 Menit</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-transparent py-2 fw-bold small text-muted">Daftar Kejadian Kerusakan (NT) Minggu Ini</div>
                            <div class="card-body p-0 table-responsive" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-sm table-striped table-hover align-middle mb-0" style="font-size: 0.85rem;">
                                    <thead class="table-dark text-center sticky-top">
                                        <tr><th>No</th><th>Tanggal</th><th>Identitas Mesin & Line</th><th>Deskripsi Masalah (Activity Text)</th><th>Durasi (Menit)</th></tr>
                                    </thead>
                                    <tbody id="tbodyDTAchievement"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalMTTR" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-top border-4 border-danger">
            <div class="modal-header bg-body-secondary py-2">
                <h5 class="modal-title fw-bold text-danger"><i class="bi bi-tools me-2"></i> Deep Dive Analytics: MTTR (Kecepatan Perbaikan)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-body-tertiary">
                <div class="row g-3">
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-header bg-transparent py-2 fw-bold small text-muted" id="headerChartMTTR">Tren MTTR Historis</div>
                            <div class="card-body p-2" style="height: 250px;">
                                <canvas id="chartMTTR"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-transparent py-2 fw-bold small text-muted">Top 10 Breakdown Terlama (Menarik Nilai Rata-rata)</div>
                            <div class="card-body p-0 table-responsive">
                                <table class="table table-sm table-striped table-hover align-middle mb-0" style="font-size: 0.85rem;">
                                    <thead class="table-dark text-center">
                                        <tr><th>No</th><th>Tanggal</th><th>Mesin</th><th>Deskripsi Masalah (Activity Text)</th><th>Durasi (Menit)</th></tr>
                                    </thead>
                                    <tbody id="tbodyMTTR"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalMTBF" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-top border-4 border-success">
            <div class="modal-header bg-body-secondary py-2">
                <h5 class="modal-title fw-bold text-success"><i class="bi bi-shield-check me-2"></i> Deep Dive Analytics: MTBF (Kehandalan Mesin)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-body-tertiary">
                <div class="row g-3">
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-header bg-transparent py-2 fw-bold small text-muted" id="headerChartMTBF">📈 Tren MTBF Historis</div>
                            <div class="card-body p-2" style="height: 250px;">
                                <canvas id="chartMTBF"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-transparent py-2 fw-bold small text-muted">ðŸ”§ Mesin Paling Sering Rusak (Frekuensi Tertinggi)</div>
                            <div class="card-body p-0 table-responsive">
                                <table class="table table-sm table-striped table-hover align-middle mb-0" style="font-size: 0.85rem;">
                                    <thead class="table-dark text-center">
                                        <tr><th>Rank</th><th>Identitas Mesin & Line</th><th>Frekuensi Rusak</th><th>Total Kehilangan Waktu</th></tr>
                                    </thead>
                                    <tbody id="tbodyMTBF"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalAvailability" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-top border-4 border-primary">
            <div class="modal-header bg-body-secondary py-2">
                <h5 class="modal-title fw-bold text-primary"><i class="bi bi-bar-chart-line me-2"></i> Deep Dive Analytics: Machine Availability</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-body-tertiary">
                <div class="row g-3">
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-header bg-transparent py-2 fw-bold small text-body-emphasis" id="headerChartAvailability">📈 Tren Availability Historis</div>
                            <div class="card-body p-2" style="height: 250px;">
                                <canvas id="chartAvailability"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-transparent py-2 fw-bold small text-body-emphasis">⚠️ Line/Mesin Penurun Availability (Downtime Tertinggi)</div>
                            <div class="card-body p-0 table-responsive">
                                <table class="table table-sm table-striped table-hover align-middle mb-0" style="font-size: 0.85rem;">
                                    <thead class="table-dark text-center">
                                        <tr><th>Rank</th><th>Identitas Mesin & Line</th><th>Total Kehilangan Waktu</th><th>Perkiraan Availability</th></tr>
                                    </thead>
                                    <tbody id="tbodyAvailability"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    window.AppConfig = { TargetDowntime: @ViewBag.TargetDowntime };
</script>
<script src="~/js/dashboard-analytics.js"></script>
<script src="~/js/dashboard-pdf-builder.js"></script>
