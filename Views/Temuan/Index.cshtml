@model IEnumerable<DashboardTeknikP1.Models.TemuanAbnormal>

@{
    ViewData["Title"] = "Log Temuan Mesin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">Rekapitulasi Temuan Abnormalitas</h2>
    <a href="/Temuan/Create" class="btn btn-success fw-bold shadow-sm">+ Input Laporan Baru</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="px-3">ID</th>
                        <th>Waktu Laporan</th>
                        <th>Pelapor</th>
                        <th>Mesin Bermasalah</th>
                        <th>Deskripsi Kendala</th>
                        <th>Tindakan / Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-3 fw-bold text-secondary">#@item.TemuanID</td>
                                <td>@item.TanggalInput.ToString("dd MMM yyyy HH:mm")</td>
                                <td><span class="badge bg-secondary">@item.UserID</span></td>
                                <td>
                                    <div class="fw-bold text-dark">@item.KodeMesin</div>
                                    <small class="text-muted">@item.NamaMesin</small>
                                </td>
                                <td>@item.DeskripsiAbnormal</td>
                                <td>
                                    <div class="mb-1 text-break">@item.TindakanKorektif</div>
                                    
                                    @if (item.StatusTemuan?.ToUpper() == "OPEN")
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge bg-danger">OPEN</span>
                                            <a href="/Temuan/Close/@item.TemuanID" class="btn btn-sm btn-outline-danger py-0 px-2 fw-bold" style="font-size: 0.75rem;">
                                                Tutup Laporan →
                                            </a>
                                        </div>
                                    }
                                    else if (item.StatusTemuan?.ToUpper() == "CLOSED")
                                    {
                                        <span class="badge bg-success">CLOSED</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">@item.StatusTemuan</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="fs-4 d-block mb-2 text-secondary">📭</i>
                                Belum ada data temuan yang dilaporkan.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>