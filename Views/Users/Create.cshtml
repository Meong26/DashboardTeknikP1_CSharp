@model DashboardTeknikP1.Models.UserCreateViewModel
@{
    ViewData["Title"] = "Tambah Pengguna";
}

<div class="container-fluid py-3">
    <div class="mb-4">
        <h2 class="h4 mb-1 fw-bold"><i class="bi bi-person-plus-fill me-2 text-primary"></i>Tambah Pengguna</h2>
        <p class="text-muted mb-0" style="font-size: 0.9rem;">Buat akun baru untuk memberikan akses sistem.</p>
    </div>

    <div class="card border-0 shadow-sm mx-auto" style="max-width: 600px; border-top: 4px solid #0d6efd !important;">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                
                <div class="mb-3">
                    <label asp-for="UserID" class="form-label fw-semibold"></label>
                    <input asp-for="UserID" class="form-control" placeholder="Masukkan NIK" />
                    <span asp-validation-for="UserID" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NamaLengkap" class="form-label fw-semibold"></label>
                    <input asp-for="NamaLengkap" class="form-control" placeholder="Nama lengkap karyawan" />
                    <span asp-validation-for="NamaLengkap" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="RoleID" class="form-label fw-semibold"></label>
                    <select asp-for="RoleID" class="form-select">
                        <option value="">-- Pilih Jabatan / Akses --</option>
                        @foreach (var role in Model.AvailableRoles)
                        {
                            <option value="@role.RoleID">@role.RoleName</option>
                        }
                    </select>
                    <span asp-validation-for="RoleID" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="Minimal 6 karakter" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="text-end border-top pt-3">
                    <a asp-action="Index" class="btn btn-light border me-2">Batal</a>
                    <button type="submit" class="btn btn-primary fw-bold"><i class="bi bi-save me-1"></i> Simpan Pengguna</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
