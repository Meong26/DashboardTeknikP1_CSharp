@{
    ViewData["Title"] = "Analitik Performa";
}

<div class="row mb-3 g-2 align-items-end">
    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Mode Dimensi Tren</label>
        <select id="dimMode" class="form-select form-select-sm border-primary" onchange="handleModeChange()">
            <option value="Year">Berdasarkan Tahun</option>
            <option value="Month">Berdasarkan Bulan</option>
            <option value="Week">Berdasarkan Minggu</option>
        </select>
    </div>

    <div class="col-md-2 d-none" id="divFltBulan">
        <label class="form-label fw-bold small text-muted mb-1 text-primary">Pilih Bulan</label>
        <select id="fltBulan" class="form-select form-select-sm border-primary" onchange="updateDashboard()">
        </select>
    </div>

    <div class="col-md-2 d-none" id="divFltMinggu">
        <label class="form-label fw-bold small text-muted mb-1 text-primary">Pilih Minggu</label>
        <select id="fltMinggu" class="form-select form-select-sm border-primary" onchange="updateDashboard()">
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Jenis Notifikasi</label>
        <select id="fltNotif" class="form-select form-select-sm" onchange="updateDashboard()">
            <option value="">Semua (NV & NT)</option>
            <option value="NV">NV - Normal</option>
            <option value="NT">NT - Teknik</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label fw-bold small text-muted mb-1">Regu / Shift</label>
        <select id="fltShift" class="form-select form-select-sm" onchange="updateDashboard()">
            <option value="">Semua Regu (A, B, C)</option>
            <option value="A">Regu A</option>
            <option value="B">Regu B</option>
            <option value="C">Regu C</option>
        </select>
    </div>

    <div class="col-md-2 mb-1">
        <div class="form-check">
            <input class="form-check-input border-danger" type="checkbox" id="chkSteam" checked onchange="updateDashboard()">
            <label class="form-check-label fw-bold small text-danger" for="chkSteam" style="font-size: 0.8rem;">
                Include Steam Drop
            </label>
        </div>
    </div>
</div>

<div class="row mb-3" style="height: 45vh;">
    <div class="col-12 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-bottom-0 d-flex justify-content-between align-items-center py-2">
                <span class="fw-bold fs-6" id="mainChartTitle">📊 Analitik Downtime vs Jam Terencana</span>
                
                <div id="drillControls" class="d-none animate__animated animate__fadeIn">
                    <div class="btn-group btn-group-sm me-3 shadow-sm" role="group">
                        <input type="radio" class="btn-check" name="drillGroup" id="dgLine" autocomplete="off" checked onchange="changeSubDrillGroup('Line')">
                        <label class="btn btn-outline-primary fw-bold" for="dgLine">Berdasarkan Line</label>
                        
                        <input type="radio" class="btn-check" name="drillGroup" id="dgMachine" autocomplete="off" onchange="changeSubDrillGroup('Machine')">
                        <label class="btn btn-outline-primary fw-bold" for="dgMachine">Berdasarkan Mesin</label>
                    </div>
                    <button class="btn btn-sm btn-secondary fw-bold shadow-sm" onclick="goBackToMainChart()">
                        <i class="bi bi-arrow-left me-1"></i> Kembali
                    </button>
                </div>
            </div>
            
            <div class="card-body p-2 position-relative">
                <canvas id="barChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row" style="height: 40vh;">
    <div class="col-md-7 h-100">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-bottom border-warning d-flex justify-content-between align-items-center py-2">
                <span class="fw-bold small">🔍 Rincian Aktivitas: <span id="lblDetail" class="text-primary">Pilih Batang Grafik</span></span>
            </div>
            <div class="card-body p-0" style="overflow-y: auto;">
                <table class="table table-sm table-hover table-striped mb-0" style="font-size: 0.85rem;">
                    <thead class="table-dark sticky-top">
                        <tr>
                            <th style="cursor:pointer" onclick="sortTable(0)">Tanggal ⇅</th>
                            <th style="cursor:pointer" onclick="sortTable(1)">Line ⇅</th>
                            <th style="cursor:pointer" onclick="sortTable(2)">Mesin ⇅</th>
                            <th>Aktivitas Perbaikan (Activity Text)</th>
                            <th style="cursor:pointer" onclick="sortTable(4)">Menit ⇅</th>
                            <th>Regu</th>
                        </tr>
                    </thead>
                    <tbody id="table-body">
                        <tr><td colspan="6" class="text-center py-4 text-muted">Klik salah satu batang grafik di atas untuk melihat detail.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-5 h-100">
        <div class="card shadow-sm h-100 border-0 d-flex flex-column">
            <div class="card-header bg-white border-bottom border-primary py-2">
                <span class="fw-bold small">🍩 Proporsi Downtime per Regu (Menit)</span>
            </div>
            <div class="card-body p-2" style="position: relative; flex-grow: 1; min-height: 0;">
                <canvas id="pieChart"></canvas>
            </div>
        </div>
    </div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>

<style>
    /* Sedikit animasi CSS agar tombol kembali muncul dengan mulus */
    .animate__fadeIn { animation: fadeIn 0.3s; }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

<script>
    Chart.register(ChartDataLabels);

    const ypDataRaw = @Html.Raw(ViewBag.DetailsJson);
    const yrDataRaw = @Html.Raw(ViewBag.Yr21Json);

    let barChartInst = null;
    let pieChartInst = null;
    
    // STATE UNTUK DRILL DOWN
    let topLevelAgg = {}; 
    let chartLevel = 0; // 0 = Grafik Utama (Waktu), 1 = Grafik Detail (Line/Mesin)
    let selectedTimeLabel = "";
    let subDrillMode = "Line"; // Mode default saat masuk ke grafik detail

    let currentDrillDownData = [];
    let sortState = { col: -1, asc: true };

    const monthNames = ["Jan", "Feb", "Mar", "Apr", "Mei", "Jun", "Jul", "Ags", "Sep", "Okt", "Nov", "Des"];
    const dayNames = ["Minggu", "Senin", "Selasa", "Rabu", "Kamis", "Jumat", "Sabtu"];

    document.addEventListener("DOMContentLoaded", () => {
        populateDynamicDropdowns();
        handleModeChange(); 
    });

    // --- KAMUS PENERJEMAH ---
    function getLineName(funcLoc) {
        if (!funcLoc) return "-";
        let parts = funcLoc.split('-');
        if (parts.length >= 4) return "Line " + Number(parts[3]); 
        return "-";
    }

    function getMachineName(funcLoc, activityText) {
        if (!funcLoc) return "-";
        let kodeMesin = funcLoc.slice(-3);
        let txt = activityText ? activityText.toLowerCase() : "";
        if (kodeMesin === "001") return "Alkali";
        if (kodeMesin === "002") return "Mixer";
        if (kodeMesin === "003") return "Feeder";
        if (kodeMesin === "004") return "Press";
        if (kodeMesin === "005") {
            if (txt.includes("tekanan") || txt.includes("drop") || txt.includes("bar") || txt.includes("dibawah") || txt.includes("di bawah") || txt.includes("turun") || txt.includes("kurang")) return "Boiler";
            return "Steambox";
        }
        if (kodeMesin === "006") return "Cutter & Distributor";
        if (kodeMesin === "007") return "Fryer";
        if (kodeMesin === "008") return "Cooler";
        if (kodeMesin === "009") {
            if (txt.includes("autoloader") || txt.includes("auto loader") || txt.includes("bumbu") || txt.includes("minyak")) return "Autoloader";
            return "Wrapper";
        }
        return funcLoc; 
    }

    // --- DROPDOWN & FILTER ---
    function populateDynamicDropdowns() {
        const ddlBulan = document.getElementById("fltBulan");
        const ddlMinggu = document.getElementById("fltMinggu");
        let bulanSet = new Set(), mingguSet = new Set();
        ypDataRaw.forEach(item => {
            let d = new Date(item.NotificationDate);
            if(d.getFullYear() > 1900) {
                bulanSet.add(JSON.stringify({ val: `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`, text: d.toLocaleDateString('id-ID', { month: 'long', year: 'numeric' }) }));
            }
            if (item.WeekKalendarIndofood) mingguSet.add(item.WeekKalendarIndofood);
        });
        Array.from(bulanSet).map(x => JSON.parse(x)).sort((a, b) => b.val.localeCompare(a.val)).forEach(item => ddlBulan.innerHTML += `<option value="${item.val}">${item.text}</option>`);
        Array.from(mingguSet).sort((a, b) => b.localeCompare(a)).forEach(w => ddlMinggu.innerHTML += `<option value="${w}">Week ${w}</option>`);
    }

    function handleModeChange() {
        const mode = document.getElementById("dimMode").value;
        document.getElementById("divFltBulan").classList.toggle("d-none", mode !== "Month");
        document.getElementById("divFltMinggu").classList.toggle("d-none", mode !== "Week");
        updateDashboard(); 
    }

    // --- FUNGSI RESET & KEMBALI ---
    function goBackToMainChart() {
        chartLevel = 0;
        document.getElementById('drillControls').classList.add('d-none');
        document.getElementById('mainChartTitle').innerText = "📊 Analitik Downtime vs Jam Terencana";
        document.getElementById('lblDetail').innerText = "Pilih Batang Grafik";
        document.getElementById('table-body').innerHTML = `<tr><td colspan="6" class="text-center py-4 text-muted">Klik salah satu batang grafik di atas untuk melihat detail.</td></tr>`;
        updateDashboard(true); 
    }

    function changeSubDrillGroup(mode) {
        subDrillMode = mode;
        renderSubChart(); // Langsung render ulang grafik yang sedang tampil
    }

    // --- OTAK UTAMA PENYARINGAN DATA ---
    function updateDashboard(isBackwards = false) {
        // Jika fungsi dipanggil oleh filter dropdown, pastikan kita reset ke level 0
        if(!isBackwards && chartLevel === 1) {
            chartLevel = 0;
            document.getElementById('drillControls').classList.add('d-none');
            document.getElementById('mainChartTitle').innerText = "📊 Analitik Downtime vs Jam Terencana";
            document.getElementById('lblDetail').innerText = "Pilih Batang Grafik";
            document.getElementById('table-body').innerHTML = `<tr><td colspan="6" class="text-center py-4 text-muted">Klik salah satu batang grafik di atas untuk melihat detail.</td></tr>`;
        }

        const mode = document.getElementById("dimMode").value;
        const fltNotif = document.getElementById("fltNotif").value;
        const fltShift = document.getElementById("fltShift").value;
        const selMonth = document.getElementById("fltBulan").value;
        const selWeek = document.getElementById("fltMinggu").value;
        const isSteamIncluded = document.getElementById("chkSteam").checked;

        const isTimeMatch = (dateObj, weekStr) => {
            if (mode === "Month") return `${dateObj.getFullYear()}-${String(dateObj.getMonth() + 1).padStart(2, '0')}` === selMonth;
            if (mode === "Week") return weekStr === selWeek;
            return true;
        };

        const ypFiltered = ypDataRaw.filter(item => {
            let mNotif = !fltNotif || (item.NotificationType && item.NotificationType.includes(fltNotif));
            let mShift = !fltShift || (item.WageGroup_GroupShift && item.WageGroup_GroupShift.includes(fltShift));
            let mTime = isTimeMatch(new Date(item.NotificationDate), item.WeekKalendarIndofood);
            let mBoiler = !(getMachineName(item.FunctionLocation, item.ActivityText) === "Boiler" && !isSteamIncluded);
            return mNotif && mShift && mTime && mBoiler;
        });

        let yrAgg = {};
        yrDataRaw.forEach(item => {
            let d = new Date(item.PostingDate);
            if (fltShift && (!item.WageGroup || !item.WageGroup.includes(fltShift))) return;
            if (!isTimeMatch(d, item.WeekOfBasicFinishedDate)) return;
            let key = getGroupingKey(d, mode);
            if (!yrAgg[key]) yrAgg[key] = 0;
            yrAgg[key] += (item.PlannedHour * 60); 
        });

        let ypAgg = {};
        ypFiltered.forEach(item => {
            let key = getGroupingKey(new Date(item.NotificationDate), mode);
            if (!ypAgg[key]) ypAgg[key] = { mins: 0, items: [] };
            ypAgg[key].mins += item.TotalDownTimeInMinutes;
            ypAgg[key].items.push(item);
        });

        // Simpan agregasi ke memori untuk dipecah di grafik ke-2 nanti
        topLevelAgg = ypAgg;

        let rawKeys = Object.keys(ypAgg);
        rawKeys.sort((a, b) => {
            if (mode === "Year") return monthNames.indexOf(a) - monthNames.indexOf(b);
            if (mode === "Week") {
                let idxA = dayNames.indexOf(a) === 0 ? 7 : dayNames.indexOf(a);
                let idxB = dayNames.indexOf(b) === 0 ? 7 : dayNames.indexOf(b);
                return idxA - idxB;
            }
            return a.localeCompare(b);
        });

        let labels = [], percentData = [], minuteData = [], targetLine = [];
        rawKeys.forEach(k => {
            labels.push(k);
            let dtMins = ypAgg[k].mins;            
            let plannedMins = yrAgg[k] || 0;       
            minuteData.push(dtMins);
            percentData.push(plannedMins > 0 ? ((dtMins / plannedMins) * 100).toFixed(2) : 0);
            targetLine.push(1.5);
        });

        renderTopChart(labels, percentData, minuteData, targetLine);
        updatePieChart(ypFiltered);
    }

    function getGroupingKey(d, mode) {
        if (mode === "Year") return monthNames[d.getMonth()]; 
        if (mode === "Month") return "Minggu Ke-" + Math.ceil(d.getDate() / 7); 
        if (mode === "Week") return dayNames[d.getDay()]; 
        return "Lainnya";
    }

    // --- LEVEL 1: RENDER GRAFIK TREN WAKTU ---
    function renderTopChart(labels, pctData, minData, targetLine) {
        const ctx = document.getElementById('barChart').getContext('2d');
        if (barChartInst) barChartInst.destroy();

        barChartInst = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    { type: 'line', label: 'Standar (1.5%)', data: targetLine, borderColor: 'rgba(220, 53, 69, 1)', borderWidth: 2, borderDash: [5, 5], pointRadius: 0, fill: false, datalabels: { display: false } },
                    { type: 'bar', label: 'Downtime (%)', data: pctData, backgroundColor: 'rgba(54, 162, 235, 0.8)', borderColor: 'rgba(54, 162, 235, 1)', borderWidth: 1, borderRadius: 4, customMinutes: minData }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    datalabels: { anchor: 'end', align: 'top', color: '#333', font: { weight: 'bold', size: 10 }, formatter: function(v, ctx) { return ctx.dataset.type === 'line' ? null : `${v}% \n(${ctx.dataset.customMinutes[ctx.dataIndex]} m)`; }, textAlign: 'center' }
                },
                scales: { y: { beginAtZero: true, suggestedMax: 3 } },
                onClick: (e, elements) => {
                    if (elements.length > 0) {
                        const idx = elements[0].index;
                        selectedTimeLabel = labels[idx];
                        
                        // Transisi ke Grafik Level 2
                        chartLevel = 1;
                        document.getElementById('drillControls').classList.remove('d-none');
                        document.getElementById('mainChartTitle').innerHTML = `📊 Rincian Periode: <span class="text-primary">${selectedTimeLabel}</span>`;
                        
                        // Gambar grafik detail dan tampilkan ke tabel
                        renderSubChart();
                        loadDrillDownTable(`Periode: ${selectedTimeLabel}`, topLevelAgg[selectedTimeLabel].items);
                    }
                }
            }
        });
    }

    // --- LEVEL 2: RENDER GRAFIK DISTRIBUSI LOKASI ---
    function renderSubChart() {
        let items = topLevelAgg[selectedTimeLabel].items;
        let subAgg = {};
        
        // Memecah data bulan/minggu yang diklik ke dalam Line atau Mesin
        items.forEach(item => {
            let key = subDrillMode === "Line" ? getLineName(item.FunctionLocation) : getMachineName(item.FunctionLocation, item.ActivityText);
            if(!subAgg[key]) subAgg[key] = { mins: 0, items: [] };
            subAgg[key].mins += item.TotalDownTimeInMinutes;
            subAgg[key].items.push(item);
        });

        let labels = Object.keys(subAgg).sort();
        let dataMins = labels.map(k => subAgg[k].mins);

        const ctx = document.getElementById('barChart').getContext('2d');
        if (barChartInst) barChartInst.destroy();

        barChartInst = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: `Total Downtime (Menit) - ${selectedTimeLabel}`,
                    data: dataMins,
                    backgroundColor: 'rgba(255, 159, 64, 0.85)', // Warna Oranye agar UX membedakan ini adalah level 2
                    borderColor: 'rgba(255, 159, 64, 1)',
                    borderWidth: 1,
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    datalabels: { anchor: 'end', align: 'top', color: '#333', font: { weight: 'bold', size: 11 }, formatter: val => `${val} m` }
                },
                scales: { y: { beginAtZero: true, suggestedMax: Math.max(...dataMins) * 1.2 } },
                onClick: (e, elements) => {
                    if (elements.length > 0) {
                        const idx = elements[0].index;
                        const key = labels[idx];
                        
                        // Melempar rincian yang lebih spesifik ke Tabel
                        loadDrillDownTable(`${selectedTimeLabel} ➔ ${key}`, subAgg[key].items);
                    }
                }
            }
        });
    }

    // --- RENDER PIE CHART ---
    function updatePieChart(filteredData) {
        let reguAgg = { "Regu A": 0, "Regu B": 0, "Regu C": 0, "Lainnya": 0 };
        filteredData.forEach(item => {
            let shift = item.WageGroup_GroupShift || "Lainnya";
            if (shift.includes("A")) reguAgg["Regu A"] += item.TotalDownTimeInMinutes;
            else if (shift.includes("B")) reguAgg["Regu B"] += item.TotalDownTimeInMinutes;
            else if (shift.includes("C")) reguAgg["Regu C"] += item.TotalDownTimeInMinutes;
            else reguAgg["Lainnya"] += item.TotalDownTimeInMinutes;
        });

        const ctx = document.getElementById('pieChart').getContext('2d');
        if (pieChartInst) pieChartInst.destroy();
        pieChartInst = new Chart(ctx, { type: 'pie', data: { labels: Object.keys(reguAgg), datasets: [{ data: Object.values(reguAgg), backgroundColor: ['rgba(255, 99, 132, 0.8)', 'rgba(54, 162, 235, 0.8)', 'rgba(255, 206, 86, 0.8)', 'rgba(201, 203, 207, 0.8)'], borderWidth: 1 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { datalabels: { color: '#fff', font: { weight: 'bold', size: 11 }, formatter: (val) => val > 0 ? `${val}m` : null } } } });
    }

    // --- TABEL DRILL DOWN & SORTING ---
    function loadDrillDownTable(title, items) {
        document.getElementById('lblDetail').innerText = title;
        currentDrillDownData = items;
        renderTableRows();
    }

    function sortTable(colIdx) {
        if (!currentDrillDownData || currentDrillDownData.length === 0) return;
        if (sortState.col === colIdx) { sortState.asc = !sortState.asc; } else { sortState.col = colIdx; sortState.asc = true; }
        currentDrillDownData.sort((a, b) => {
            let valA, valB;
            if (colIdx === 0) { valA = new Date(a.NotificationDate); valB = new Date(b.NotificationDate); }
            else if (colIdx === 1) { valA = getLineName(a.FunctionLocation); valB = getLineName(b.FunctionLocation); }
            else if (colIdx === 2) { valA = getMachineName(a.FunctionLocation, a.ActivityText); valB = getMachineName(b.FunctionLocation, b.ActivityText); }
            else if (colIdx === 4) { valA = a.TotalDownTimeInMinutes; valB = b.TotalDownTimeInMinutes; }
            if (valA < valB) return sortState.asc ? -1 : 1;
            if (valA > valB) return sortState.asc ? 1 : -1;
            return 0;
        });
        renderTableRows();
    }

    function renderTableRows() {
        const tbody = document.getElementById('table-body');
        if(currentDrillDownData.length === 0) { tbody.innerHTML = `<tr><td colspan="6" class="text-center py-3">Tidak ada data.</td></tr>`; return; }
        let html = "";
        currentDrillDownData.forEach(item => {
            const fDate = new Date(item.NotificationDate).toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
            let txtAktivitas = item.ActivityText ? item.ActivityText : (item.NotificationDesc || '-');
            let namaLine = getLineName(item.FunctionLocation);
            let namaMesin = getMachineName(item.FunctionLocation, item.ActivityText);
            html += `<tr>
                <td>${fDate}</td>
                <td class="fw-bold text-success">${namaLine}</td>
                <td class="fw-bold text-primary">${namaMesin}</td>
                <td class="text-truncate" style="max-width: 230px;" title="${txtAktivitas}">${txtAktivitas}</td>
                <td class="text-danger fw-bold">${item.TotalDownTimeInMinutes}</td>
                <td><span class="badge bg-secondary">${item.WageGroup_GroupShift || '-'}</span></td>
            </tr>`;
        });
        tbody.innerHTML = html;
    }
</script>