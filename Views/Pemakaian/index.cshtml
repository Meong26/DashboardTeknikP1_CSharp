@{
    ViewData["Title"] = "Pemakaian Sparepart";
}

<div class="row mb-2 align-items-center" style="height: 8vh;">
    <div class="col">
        <h4 class="fw-bold text-primary mb-0"><i class="bi bi-cart-dash me-2"></i> Monitoring Pemakaian Part</h4>
        <small class="text-muted">Pantau biaya dan input riwayat pengambilan suku cadang harian.</small>
    </div>
</div>

<ul class="nav nav-tabs mb-3 shadow-sm" id="monitoringTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active fw-bold text-primary" id="estimasi-tab" data-bs-toggle="tab" data-bs-target="#estimasi-tab-pane" type="button" role="tab" aria-controls="estimasi-tab-pane" aria-selected="true" onclick="toggleHistoryMode('ESTIMASI')">Total Pengeluaran Estimasi</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link fw-bold text-success" id="goodsissue-tab" data-bs-toggle="tab" data-bs-target="#goodsissue-tab-pane" type="button" role="tab" aria-controls="goodsissue-tab-pane" aria-selected="false" onclick="toggleHistoryMode('FIX')">Total Pengeluaran Goods Issue</button>
  </li>
</ul>

<div class="tab-content mb-4" id="monitoringTabsContent">
  <!-- TAB 1: ESTIMASI -->
  <div class="tab-pane fade show active" id="estimasi-tab-pane" role="tabpanel" aria-labelledby="estimasi-tab" tabindex="0">
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow-sm border-0" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body py-3">
                    <div class="small fw-bold text-uppercase opacity-75 mb-1">Total Pengeluaran Sparepart</div>
                    <h3 class="mb-0 fw-bold">Rp <span id="lblCostThisWeek">0</span></h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white shadow-sm border-0" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body py-3">
                    <div class="small fw-bold text-uppercase opacity-75 mb-1">Output Produksi</div>
                    <h3 class="mb-0 fw-bold"><span id="lblOutputThisWeek">0</span> <span class="fs-6 fw-normal">Pcs</span></h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white shadow-sm border-0" id="cardRatioThisWeek" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body py-3">
                    <div class="small fw-bold text-uppercase opacity-75 mb-1">RM Cost</div>
                    <h3 class="mb-0 fw-bold"><span id="lblRatioThisWeek">0.00</span> <span class="fs-6 fw-normal">Rp/Pcs</span></h3>
                    <div class="small fw-bold opacity-75 mt-1">Standar: Rp 1,75/Pcs</div>
                </div>
            </div>
        </div>
    </div>
  </div>

  <!-- TAB 2: GOODS ISSUE -->
  <div class="tab-pane fade" id="goodsissue-tab-pane" role="tabpanel" aria-labelledby="goodsissue-tab" tabindex="0">
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card bg-success text-white shadow-sm border-0" title="Klik untuk melihat Detail Data SAP YP14" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body py-3">
                    <div class="small fw-bold text-uppercase opacity-75 mb-1">Total Pengeluaran Sparepart</div>
                    <h3 class="mb-0 fw-bold">Rp <span id="lblCostLastWeek">0</span></h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white shadow-sm border-0" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body py-3">
                    <div class="small fw-bold text-uppercase opacity-75 mb-1">Output Produksi</div>
                    <h3 class="mb-0 fw-bold"><span id="lblOutputLastWeek">0</span> <span class="fs-6 fw-normal">Pcs</span></h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white shadow-sm border-0" id="cardRatioLastWeek" style="transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="card-body py-3">
                    <div class="small fw-bold text-uppercase opacity-75 mb-1">RM Cost</div>
                    <h3 class="mb-0 fw-bold"><span id="lblRatioLastWeek">0.00</span> <span class="fs-6 fw-normal">Rp/Pcs</span></h3>
                    <div class="small fw-bold opacity-75 mt-1">Standar: Rp 1,75/Pcs</div>
                </div>
            </div>
        </div>
    </div>
  </div>
</div>

<div id="formPengambilanContainer" class="card shadow-sm border-0 border-top border-4 border-success mb-4 d-print-none">
    <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
        <span class="fw-bold text-success" style="font-size: 0.9rem;"><i class="bi bi-table me-1"></i> Form Pengambilan (Input Cepat)</span>
        <div class="spinner-border spinner-border-sm text-primary d-none" id="loadingMaster"></div>
    </div>
    <div class="card-body p-0 table-responsive" style="max-height: 25vh; overflow-y: auto;">
        <table class="table table-bordered table-sm align-middle mb-0" style="font-size: 0.85rem;" id="tblInput">
            <thead class="table-light sticky-top">
                <tr class="text-center">
                    <th style="width: 11%;">Tgl Ambil</th>
                    <th style="width: 13%;">No Material</th>
                    <th style="width: 22%;">Material Desc</th>
                    <th style="width: 15%;">Tujuan Pengambilan</th>
                    <th style="width: 14%;">Nama Pengambil</th>
                    <th style="width: 10%;">Plant</th>
                    <th style="width: 6%;">Qty</th>
                    <th style="width: 6%;">Sisa Stok</th>
                    <th style="width: 3%;"></th>
                </tr>
            </thead>
            <tbody id="inputBody"></tbody>
        </table>
    </div>
    <div class="card-footer bg-white py-2 d-flex justify-content-between align-items-center">
        <button class="btn btn-sm btn-outline-secondary fw-bold" onclick="addNewRow()">+ Tambah Baris (Manual)</button>
        <button class="btn btn-sm btn-success fw-bold px-4 shadow-sm" onclick="saveData()">
            <i class="bi bi-save me-1"></i> Simpan Data Pengambilan
        </button>
    </div>
</div>

<div class="card shadow-sm border-0 border-top border-4 border-primary">
    <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center d-print-none">
        <span class="fw-bold text-primary" style="font-size: 0.9rem;">
            <i class="bi bi-clock-history me-1"></i> Riwayat Pengambilan Suku Cadang
        </span>
        <div class="d-flex align-items-center gap-2">
            
            @if (!User.IsInRole("WHS.SP"))
            {
                <button id="btnModePR" class="btn btn-sm btn-outline-info fw-bold shadow-sm" onclick="toggleModePRUI()">
                    <i class="bi bi-cart-plus me-1"></i> Mode Order PR
                </button>
                <button id="btnExecutePR" class="btn btn-sm btn-info fw-bold shadow-sm d-none text-white" onclick="submitOrderPR()">
                    <i class="bi bi-file-earmark-spreadsheet me-1"></i> Buat Dokumen PR
                </button>

                <button id="btnModeKarantina" class="btn btn-sm btn-outline-danger fw-bold shadow-sm" onclick="toggleModeKarantinaUI()">
                    <i class="bi bi-pencil-square me-1"></i> Karantina / Edit
                </button>
                <button id="btnExecuteKarantina" class="btn btn-sm btn-danger fw-bold shadow-sm d-none" onclick="submitKarantinaBulk()">
                    <i class="bi bi-exclamation-octagon-fill me-1"></i> Simpan ke Karantina
                </button>

                <button id="btnPrintReport" class="btn btn-sm btn-dark fw-bold shadow-sm" onclick="printLaporanLolos()">
                    <i class="bi bi-printer me-1"></i> Cetak Lap. Lolos
                </button>
                <button class="btn btn-sm btn-warning fw-bold shadow-sm border border-warning-subtle position-relative me-2" data-bs-toggle="modal" data-bs-target="#modalKarantina">
                    <i class="bi bi-shield-exclamation me-1"></i> Data Karantina
                    <span id="badgeKarantinaCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">0</span>
                </button>
            }

            <select id="historyWeekFilter" class="form-select form-select-sm border-primary shadow-sm" onchange="renderHistoryTable()" style="width: auto; min-width: 150px;">
            </select>
            <select id="historyPlantFilter" class="form-select form-select-sm border-secondary shadow-sm" onchange="renderHistoryTable()" style="width: auto; min-width: 120px;">
                <option value="">Semua Plant</option>
                <option value="Plant 1">Plant 1</option>
                <option value="Plant 2">Plant 2</option>
                <option value="Plant 3">Plant 3</option>
            </select>
        </div>
    </div>
    
    <div class="d-none d-print-block text-center mb-3">
        <h4 class="fw-bold mb-0">LAPORAN REKAPITULASI PEMAKAIAN SPAREPART (LOLOS VERIFIKASI)</h4>
        <p class="text-secondary small">Printed Date: @DateTime.Now.ToString("dd MMMM yyyy HH:mm") | Requester: Djaka Ramdhani</p>
    </div>
    
    <div class="card-body p-0 table-responsive" style="max-height: 35vh; overflow-y: auto;" id="printArea">
        <table class="table table-hover table-striped table-bordered table-sm align-middle mb-0" style="font-size: 0.85rem;" id="mainHistoryTable">
            <thead class="table-dark sticky-top">
                <tr class="text-center" id="historyTheadRow"></tr>
            </thead>
            <tbody id="historyTableBody">
                <tr><td colspan="9" class="text-center py-4 text-muted">Memuat riwayat pengambilan...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalKarantina" tabindex="-1" aria-labelledby="modalKarantinaLabel" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-top border-4 border-danger">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold text-danger" id="modalKarantinaLabel">
                    <i class="bi bi-shield-exclamation me-2"></i> Gudang Karantina Anggaran (Shadow Ledger)
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <table class="table table-bordered table-striped table-sm align-middle mb-0" style="font-size: 0.85rem;">
                    <thead class="table-dark sticky-top">
                        <tr class="text-center">
                            <th>Tanggal Masuk</th>
                            <th>No Material</th>
                            <th>Deskripsi Suku Cadang</th>
                            <th>Tujuan / Mesin</th>
                            <th>Nama Pengambil</th>
                            <th style="width: 5%;">Qty</th>
                            <th>Total Nilai</th>
                            <th style="width: 250px;">Aksi Kendali Anggaran</th>
                        </tr>
                    </thead>
                    <tbody id="karantinaTableBody">
                        <tr><td colspan="8" class="text-center py-4 text-muted">Tidak ada data di gudang karantina.</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer bg-light py-2">
                <button type="button" class="btn btn-sm btn-secondary fw-bold" data-bs-dismiss="modal">Tutup Jendela</button>
            </div>
        </div>
    </div>
</div>
<div id="autoCompleteDropdown" class="list-group shadow-lg position-absolute d-none" style="z-index: 9999; max-height: 300px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 6px;"></div>
<div id="autoCompleteTeknisiDropdown" class="list-group shadow-lg position-absolute d-none" style="z-index: 9999; max-height: 250px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 6px;"></div>

<script src="~/js/pemakaian.js"></script>
