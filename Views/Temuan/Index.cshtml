@model IEnumerable<DashboardTeknikP1.Models.TemuanAbnormal>

@{
    ViewData["Title"] = "Log Temuan Mesin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">Rekapitulasi Temuan Abnormalitas</h2>
    <a href="/Temuan/Create" class="btn btn-success fw-bold">+ Input Laporan Baru</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Waktu Laporan</th>
                    <th>Pelapor (NIK)</th>
                    <th>Mesin</th>
                    <th>Deskripsi Kendala</th>
                    <th>Tindakan / Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.TemuanID</td>
                            <td>@item.TanggalInput.ToString("dd MMM yyyy HH:mm")</td>
                            <td><span class="badge bg-secondary">@item.UserID</span></td>
                            <td class="fw-bold">@item.MesinID</td>
                            <td>@item.DeskripsiAbnormal</td>
                            <td>
                                <div>@item.TindakanKorektif</div>
                                @if (item.StatusTemuan == "Open")
                                {
                                    <span class="badge bg-danger mt-1">Open</span>
                                }
                                else
                                {
                                    <span class="badge bg-success mt-1">@item.StatusTemuan</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Belum ada data temuan yang dilaporkan.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>