@{
    Layout = null;
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TV Dashboard Mode - Teknik P1</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/lib/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { overflow: hidden; background-color: #f8f9fa; margin: 0; padding: 0; height: 100vh; width: 100vw; }
        
        .tv-header {
            position: absolute; top: 0; left: 0; right: 0; height: 80px;
            background: linear-gradient(135deg, #212529 0%, #343a40 100%);
            color: white; display: flex; align-items: center; justify-content: center; z-index: 1000;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }
        
        .tv-header img { height: 50px; margin-right: 15px; }
        .tv-header h1 { margin: 0; font-size: 2rem; font-weight: bold; letter-spacing: 1px; color: #ffc107; }

        .carousel-container {
            position: absolute; top: 80px; left: 0; right: 0; bottom: 0;
            padding: 20px;
        }

        .carousel, .carousel-inner, .carousel-item {
            height: 100%; width: 100%; cursor: pointer;
        }

        .slide-content {
            height: 100%; display: flex; flex-direction: column;
            background: white; border-radius: 15px; padding: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .slide-title { font-size: 1.8rem; font-weight: bold; color: #333; margin-bottom: 20px; text-align: center; border-bottom: 2px solid #dc3545; padding-bottom: 10px; }
        .chart-wrapper { flex-grow: 1; position: relative; min-height: 0; }
        
        table { font-size: 1.2rem; }
        th { background-color: #343a40 !important; color: white !important; }
        td, th { padding: 15px !important; vertical-align: middle; }

        .kpi-card { background: #f8f9fa; border-radius: 10px; padding: 30px; text-align: center; border: 1px solid #dee2e6; height: 100%; display: flex; flex-direction: column; justify-content: center; }
        .kpi-value { font-size: 4rem; font-weight: bold; color: #dc3545; margin-top: 15px; }
        .kpi-label { font-size: 1.5rem; color: #6c757d; font-weight: bold; }

        .loading-overlay {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.9);
            z-index: 2000; display: flex; flex-direction: column; align-items: center; justify-content: center;
        }
        
        .tv-logout-btn {
            opacity: 0.2; transition: opacity 0.3s;
        }
        .tv-logout-btn:hover {
            opacity: 1;
        }
        
        .carousel-control-prev, .carousel-control-next {
            opacity: 0 !important;
            transition: opacity 0.4s ease-in-out;
        }
        .carousel-control-prev:hover, .carousel-control-next:hover {
            opacity: 0.9 !important;
        }
    </style>
</head>
<body>
    <div class="loading-overlay" id="loadingOverlay">
        <div class="spinner-border text-danger" style="width: 4rem; height: 4rem;" role="status"></div>
        <h3 class="mt-4 text-dark fw-bold">Memuat Data TV Dashboard...</h3>
    </div>

    <div class="tv-header position-relative">
        <div class="d-flex align-items-center justify-content-center w-100">
            <img src="~/images/logo_indofood.svg" alt="Logo Indofood">
            <h1>Teknik P1 Super App</h1>
        </div>
        <form asp-controller="Auth" asp-action="Logout" method="post" class="position-absolute end-0 me-4">
            <button type="submit" class="btn btn-outline-light btn-sm tv-logout-btn" title="Keluar (Logout)">
                <i class="bi bi-box-arrow-right fs-5"></i>
            </button>
        </form>
    </div>

    <div class="carousel-container">
        <div id="tvCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="@ViewBag.TvModeDuration">
            <div class="carousel-inner" id="carouselInner">
                <!-- Slides will be injected here -->
            </div>
            
            <button class="carousel-control-prev" type="button" data-bs-target="#tvCarousel" data-bs-slide="prev" style="width: 5%;">
                <span class="carousel-control-prev-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#tvCarousel" data-bs-slide="next" style="width: 5%;">
                <span class="carousel-control-next-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
            </button>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/chartjs/chart.min.js"></script>
    <script src="~/lib/chartjs/chartjs-plugin-datalabels.min.js"></script>
    
    
<script>
    window.AppConfig = {
        TvModeDuration: @ViewBag.TvModeDuration,
        TargetDowntime: @ViewBag.TargetDowntime
    };
</script>
<script src="~/js/tvdashboard.js"></script>

</body>
</html>
