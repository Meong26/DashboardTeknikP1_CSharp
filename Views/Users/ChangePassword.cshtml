@model DashboardTeknikP1.Models.UserChangePasswordViewModel
@{
    ViewData["Title"] = "Ganti Kata Sandi";
}

<div class="container-fluid py-3">
    <div class="mb-4">
        <h2 class="h4 mb-1 fw-bold"><i class="bi bi-key-fill me-2 text-warning"></i>Ganti Kata Sandi</h2>
        <p class="text-muted mb-0" style="font-size: 0.9rem;">Ubah kata sandi untuk akun <strong>@Model.NamaLengkap</strong> (@Model.UserID)</p>
    </div>

    <div class="card border-0 shadow-sm mx-auto" style="max-width: 600px; border-top: 4px solid #ffc107 !important;">
        <div class="card-body p-4">
            <form asp-action="ChangePassword" method="post">
                <input type="hidden" asp-for="UserID" />
                <input type="hidden" asp-for="NamaLengkap" />

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="NewPassword" type="password" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="text-end border-top pt-3">
                    <a asp-action="Index" class="btn btn-light border me-2">Batal</a>
                    <button type="submit" class="btn btn-warning fw-bold text-dark"><i class="bi bi-shield-lock-fill me-1"></i> Perbarui Sandi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
